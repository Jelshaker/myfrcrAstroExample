---
export interface PricingFeature {
  title: string;
  description?: string;
}

export interface PricingPlan {
  title: string;
  subtitle?: string;
  price: string;
  currency?: string;
  period?: string;
  features: PricingFeature[];
  ctaText: string;
  ctaHref?: string;
  footerText?: string;
  disclaimer?: string;
  featured?: boolean;
  badge?: string;
}

export interface Props {
  plan: PricingPlan;
  variant?: 'default' | 'compact';
}

const { plan, variant = 'default' } = Astro.props;

const {
  title,
  subtitle,
  price,
  currency = '£',
  period = '',
  features,
  ctaText,
  ctaHref = '#',
  footerText,
  disclaimer,
  featured = false,
  badge,
} = plan;
---

<div class:list={['pricing-card', featured && 'pricing-card--featured']}>
  {badge && (
    <div class="pricing-badge">{badge}</div>
  )}

  <div class="pricing-header">
    <h3 class="pricing-subtitle">{title}</h3>
    {subtitle && <p class="pricing-subtitle-desc">{subtitle}</p>}

    <div class="pricing-price">
      {currency && <span class="pricing-currency">{currency}</span>}
      {price}
      {period && <span class="pricing-period">/{period}</span>}
    </div>
  </div>

  <ul class="pricing-features">
    {features.map((feature) => (
      <li class="pricing-feature">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12" />
        </svg>
        <div>
          <span class="pricing-feature-title">{feature.title}</span>
          {feature.description && (
            <p class="pricing-feature-desc">{feature.description}</p>
          )}
        </div>
      </li>
    ))}
  </ul>

  <a href={ctaHref} class="pricing-cta">{ctaText}</a>

  {footerText && <p class="pricing-footer-text">{footerText}</p>}

  {disclaimer && <p class="pricing-disclaimer">{disclaimer}</p>}
</div>

<style>
  .pricing-card {
    max-width: 36rem;
    margin: 0 auto;
    background: var(--color-white);
    border: 2px solid var(--color-blue-500);
    border-radius: var(--radius-2xl);
    padding: 1.5rem;
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .pricing-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 30px -5px rgba(37, 99, 235, 0.2);
  }

  .pricing-card--featured {
    border-color: var(--color-indigo-600);
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.15), var(--shadow-xl);
    transform: scale(1.02);
  }

  .pricing-card--featured:hover {
    box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.25), 0 25px 30px -5px rgba(79, 70, 229, 0.25);
    transform: scale(1.02) translateY(-2px);
  }

  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-indigo-600);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 1.25rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .pricing-header {
    text-align: center;
  }

  .pricing-subtitle {
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
  }

  .pricing-subtitle-desc {
    font-size: 0.875rem;
    color: var(--color-gray-500);
    margin-top: 0.25rem;
  }

  .pricing-price {
    font-size: 3rem;
    color: var(--color-blue-600);
    font-weight: 700;
    line-height: 1.1;
  }

  .pricing-currency {
    font-size: 1.5rem;
    vertical-align: super;
    margin-right: 0.125rem;
  }

  .pricing-period {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-gray-500);
  }

  .pricing-features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
  }

  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .pricing-feature svg {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-blue-600);
    margin-top: 0.25rem;
    flex-shrink: 0;
  }

  .pricing-feature-title {
    font-weight: 600;
  }

  .pricing-feature-desc {
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .pricing-cta {
    width: 100%;
    padding: 0.75rem;
    background: var(--color-blue-600);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-xl);
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    text-align: center;
    display: inline-block;
    text-decoration: none;
  }

  .pricing-cta:hover {
    background: #1d4ed8;
  }

  .pricing-footer-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-gray-600);
  }

  .pricing-disclaimer {
    text-align: center;
    color: var(--color-gray-600);
    margin-top: 1.5rem;
    max-width: 36rem;
    margin-left: auto;
    margin-right: auto;
  }

  /* --- Compact Variant --- */
  .pricing-card:not(:has(.pricing-card--featured)):has(.pricing-currency),
  .pricing-card.variant-compact .pricing-price {
    /* compact is handled via the variant prop */
  }
</style>