---
export interface PhysicsResource {
  title: string;
  description: string;
  href: string;
  badge?: string;
}

export interface Props {
  resource: PhysicsResource;
}

const { resource } = Astro.props;
const { title, description, href, badge } = resource;
---

<div class="physics-card">
  {badge && <span class="physics-badge">{badge}</span>}

  <div class="physics-card-header">
    <svg class="physics-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </svg>
    <h3 class="physics-title">{title}</h3>
  </div>

  <p class="physics-description">{description}</p>

  <div class="physics-details">
    <div class="physics-detail-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
        <line x1="16" y1="13" x2="8" y2="13" />
        <line x1="16" y1="17" x2="8" y2="17" />
        <polyline points="10 9 9 9 8 9" />
      </svg>
      <span>RCR Official Specimen Questions</span>
    </div>
    <div class="physics-detail-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span>Physics Module — Part 1 CR1</span>
    </div>
  </div>

  <a href={href} class="physics-cta" target="_blank" rel="noopener noreferrer">
    View Specimen Questions
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 17l9.2-9.2M17 17V7H7" />
    </svg>
  </a>
</div>

<style>
  .physics-card {
    max-width: 36rem;
    margin: 0 auto;
    background: var(--color-white);
    border: 2px solid var(--color-blue-500);
    border-radius: var(--radius-2xl);
    padding: 1.75rem;
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .physics-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 30px -5px rgba(37, 99, 235, 0.2);
  }

  .physics-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-indigo-600);
    color: var(--color-white);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 1.25rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .physics-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .physics-icon {
    color: var(--color-blue-600);
    flex-shrink: 0;
  }

  .physics-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0;
  }

  .physics-description {
    font-size: 0.9375rem;
    color: var(--color-gray-600);
    line-height: 1.6;
    margin: 0;
  }

  .physics-details {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
    padding: 1rem 1.25rem;
  }

  .physics-detail-item {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.875rem;
    color: var(--color-gray-700);
    font-weight: 500;
  }

  .physics-detail-item svg {
    color: var(--color-blue-600);
    flex-shrink: 0;
  }

  .physics-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.75rem 1.5rem;
    background: var(--color-blue-600);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-xl);
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s;
    text-align: center;
    text-decoration: none;
  }

  .physics-cta:hover {
    background: #1d4ed8;
  }

  .physics-cta svg {
    transition: transform 0.2s ease;
  }

  .physics-cta:hover svg {
    transform: translate(2px, -2px);
  }
</style>