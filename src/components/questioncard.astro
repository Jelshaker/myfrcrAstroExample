---
export interface QuestionStatement {
  label: string; // a, b, c, d, e
  text: string;
}

export interface QuestionAnswer {
  label: string; // a, b, c, d, e
  correct: boolean;
  explanation: string;
}

export interface PhysicsQuestion {
  number: number;
  stem: string;
  statements: QuestionStatement[];
  answers: QuestionAnswer[];
}

export interface Props {
  question: PhysicsQuestion;
}

const { question } = Astro.props;
const { number, stem, statements, answers } = question;
---

<div class="question-card">
  <span class="question-badge">Question {number}</span>

  <div class="stem-section">
    <p class="stem-label"><strong>Stem:</strong> {stem}</p>
  </div>

  <div class="statements-section">
    <ol class="statements-list">
      {statements.map((stmt) => (
        <li value={stmt.label.charCodeAt(0) - 96} class="statement-item">
          <span class="statement-label">{stmt.label})</span>
          <span class="statement-text">{stmt.text}</span>
        </li>
      ))}
    </ol>
  </div>

  <div class="answers-section">
    <h4 class="answers-heading">Answers & Explanations:</h4>
    <ul class="answers-list">
      {answers.map((ans) => (
        <li class="answer-item">
          <span class="answer-label">({ans.label})</span>
          <span class={`answer-badge ${ans.correct ? 'answer-true' : 'answer-false'}`}>
            {ans.correct ? 'True' : 'False'}
          </span>
          <span class="answer-explanation">{ans.explanation}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .question-card {
    max-width: 42rem;
    margin: 0 auto;
    background: var(--color-white);
    border: 2px solid var(--color-blue-500);
    border-radius: var(--radius-2xl);
    padding: 1.75rem;
    box-shadow: var(--shadow-xl);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    position: relative;
    transition: all 0.3s ease;
  }

  .question-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 25px 30px -5px rgba(37, 99, 235, 0.2);
  }

  .question-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-indigo-600);
    color: var(--color-white);
    font-size: 0.875rem;
    font-weight: 700;
    padding: 0.35rem 1.5rem;
    border-radius: 9999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .stem-section {
    margin-top: 0.5rem;
  }

  .stem-label {
    font-size: 0.9375rem;
    color: var(--color-gray-800);
    line-height: 1.7;
    margin: 0;
  }

  .stem-label strong {
    color: var(--color-gray-900);
  }

  .statements-section {
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.5rem;
    border-left: 4px solid var(--color-blue-500);
  }

  .statements-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .statement-item {
    display: flex;
    gap: 0.5rem;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-gray-700);
  }

  .statement-label {
    font-weight: 600;
    color: var(--color-blue-700);
    flex-shrink: 0;
    min-width: 1.5rem;
  }

  .statement-text {
    color: var(--color-gray-700);
  }

  .answers-section {
    border-radius: var(--radius-xl);
    padding: 1.25rem 1.5rem;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
  }

  .answers-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin: 0 0 1rem 0;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid var(--color-gray-100);
  }

  .answers-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .answer-item {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: var(--color-gray-700);
    align-items: flex-start;
  }

  .answer-label {
    font-weight: 600;
    color: var(--color-gray-800);
    flex-shrink: 0;
    min-width: 1.5rem;
  }

  .answer-badge {
    flex-shrink: 0;
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.125rem 0.625rem;
    border-radius: 9999px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-top: 0.125rem;
  }

  .answer-true {
    background: #dcfce7;
    color: #166534;
  }

  .answer-false {
    background: #fce4ec;
    color: #c62828;
  }

  .answer-explanation {
    color: var(--color-gray-600);
    flex: 1;
  }

  .statements-list .statement-item .statement-label {
    font-weight: 600;
    color: var(--color-blue-700);
  }
</style>