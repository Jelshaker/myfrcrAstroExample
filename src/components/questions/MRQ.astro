---
export interface MRQStatement {
  label: string; // a, b, c, d, e
  text: string;
}

export interface MRQAnswer {
  label: string; // a, b, c, d, e
  text: string; // e.g. "Correct Best Answer" or "Incorrect"
  correct: boolean;
}

export interface MRQQuestion {
  number: number;
  stem: string;
  statements: MRQStatement[];
  answers: MRQAnswer[];
  explanation: string;
  freeText?: boolean; // if true, shows a text box instead of checkbox statements
}

export interface Props {
  questions?: MRQQuestion[];
  sectionId?: string;
  title?: string;
  subtitle?: string;
}

const defaultQuestions: MRQQuestion[] = [
  {
    number: 1,
    stem: 'Concerning/In [Insert Topic or Core Statement Here]: / may include .jpg or .png images',
    statements: [
      { label: 'a', text: '[Statement 1]' },
      { label: 'b', text: '[Statement 2]' },
      { label: 'c', text: '[Statement 3]' },
      { label: 'd', text: '[Statement 4]' },
      { label: 'e', text: '[Statement 5]' },
    ],
    answers: [
      { label: 'a', text: 'Incorrect', correct: false },
      { label: 'b', text: 'Incorrect', correct: false },
      { label: 'c', text: 'Correct Best Answer', correct: true },
      { label: 'd', text: 'Incorrect', correct: false },
      { label: 'e', text: 'Incorrect', correct: false },
    ],
    explanation: '[Insert the detailed physics principle here. Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
    freeText: false,
  },

];

const { questions = defaultQuestions } = Astro.props;
const sectionId = Astro.props.sectionId || 'mrq-sample';
const title = Astro.props.title || 'Sample MRQ Questions';
const subtitle = Astro.props.subtitle || 'Live practice questions in the Multiple Response format with answers and explanations';
---

<section class="section section-gray" id={sectionId}>
  <div class="container">
    <h2 class="section-title text-center">{title}</h2>
    <p class="section-subtitle">{subtitle}</p>

    <div class="questions-grid">
      {questions.map((q) => (
        <div class="question-block">
          <h3 class="question-heading">### Question {q.number}</h3>

          <p class="question-stem">
            <strong>Stem:</strong> {q.stem}
          </p>

          {q.freeText ? (
            <div class="free-text-area" style="margin-top: 15px;">
              <label for={`free-text-${q.number}`} style="display: block; margin-bottom: 8px; font-weight: bold;">
                Your Answer:
              </label>
              <textarea
                id={`free-text-${q.number}`}
                rows="6"
                style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; font-family: inherit; font-size: 1rem; resize: vertical;"
                placeholder="Type your answer here..."
              ></textarea>
            </div>
          ) : (
            <ol class="question-options" type="a">
              {q.statements.map((stmt) => (
                <li><input type="checkbox" name={`mrq-question-${q.number}`} /> {stmt.text}</li>
              ))}
            </ol>
          )}

          <div class="answers-section">
            {q.freeText ? (
              <div
                class="explanation-box"
                style="margin-top: 15px; padding: 15px; border: 1px solid #ccc; background-color: #f9f9f9; border-radius: 5px;"
              >
                <h5>Model Answer / Guidance:</h5>
                <p>{q.explanation}</p>
              </div>
            ) : (
              <>
                <h4>Answer Options:</h4>
                <ul class="answers-list">
                  {q.answers.map((ans) => (
                    <li>
                      <strong>({ans.label})</strong> {ans.text}{' '}
                      {ans.correct
                        ? <span style="color: green; float: right;">&#10003;</span>
                        : <span style="color: red; float: right;">&#10007;</span>}
                    </li>
                  ))}
                </ul>

                <div
                  class="explanation-box"
                  style="margin-top: 15px; padding: 15px; border: 1px solid #ccc; background-color: #f9f9f9; border-radius: 5px;"
                >
                  <h5>Explanation:</h5>
                  <p>{q.explanation}</p>
                </div>
              </>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>