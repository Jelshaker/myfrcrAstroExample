---
export interface shortcasesstatement {
  label: string; // a, b, c, d, e
  text: string;
}

export interface shortcasesanswer {
  label: string; // a, b, c, d, e
  text: string; // e.g. "Correct Best Answer" or "Incorrect"
  correct: boolean;
}

export interface shortcasesquestion {
  number: number;
  stem: string;
  statements: shortcasesstatement[];
  answers: shortcasesanswer[];
  explanation: string;
  freeText?: boolean; // if true, shows a text box instead of checkbox statements
}

export interface Props {
  questions: shortcasesquestion[];
}

const { questions } = Astro.props;
---

<div class="questions-grid">
  {questions.map((q) => (
    <div class="question-block">
      <h3 class="question-heading">### Question {q.number}</h3>

      <p class="question-stem">
        <strong>Stem:</strong> {q.stem}
      </p>

      {q.freeText ? (
        <div class="free-text-area" style="margin-top: 15px;">
          <label for={`free-text-${q.number}`} style="display: block; margin-bottom: 8px; font-weight: bold;">
            Your Answer:
          </label>
          <textarea
            id={`free-text-${q.number}`}
            rows="6"
            style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 5px; font-family: inherit; font-size: 1rem; resize: vertical;"
            placeholder="Type your answer here..."
          ></textarea>
        </div>
      ) : (
        <ol class="question-options" type="a">
          {q.statements.map((stmt) => (
            <li><input type="checkbox" name={`shortcases-question-${q.number}`} /> {stmt.text}</li>
          ))}
        </ol>
      )}

      <div class="answers-section">
        {q.freeText ? (
          <div
            class="explanation-box"
            style="margin-top: 15px; padding: 15px; border: 1px solid #ccc; background-color: #f9f9f9; border-radius: 5px;"
          >
            <h5>Model Answer / Guidance:</h5>
            <p>{q.explanation}</p>
          </div>
        ) : (
          <>
            <h4>Answer Options:</h4>
            <ul class="answers-list">
              {q.answers.map((ans) => (
                <li>
                  <strong>({ans.label})</strong> {ans.text}{' '}
                  {ans.correct
                    ? <span style="color: green; float: right;">&#10003;</span>
                    : <span style="color: red; float: right;">&#10007;</span>}
                </li>
              ))}
            </ul>

            <div
              class="explanation-box"
              style="margin-top: 15px; padding: 15px; border: 1px solid #ccc; background-color: #f9f9f9; border-radius: 5px;"
            >
              <h5>Explanation:</h5>
              <p>{q.explanation}</p>
            </div>
          </>
        )}
      </div>
    </div>
  ))}
</div>