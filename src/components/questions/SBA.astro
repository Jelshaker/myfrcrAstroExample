---
export interface SBAStatement {
  label: string; // a, b, c, d, e
  text: string;
}

export interface SBAAnswer {
  label: string; // a, b, c, d, e
  text: string; // e.g. "Correct Best Answer" or "Incorrect"
  correct: boolean;
}

export interface SBAQuestion {
  number: number;
  stem: string;
  statements: SBAStatement[];
  answers: SBAAnswer[];
  explanation: string;
}

export interface Props {
  question: SBAQuestion;
}

const { question } = Astro.props;
const { number, stem, statements, answers, explanation } = question;
---

<div class="question-block">
  <h3 class="question-heading">### Question {number}</h3>

  <p class="question-stem">
    <strong>Stem:</strong> {stem}
  </p>

  <ol class="question-options" type="a">
    {statements.map((stmt) => (
      <li>{stmt.text}</li>
    ))}
  </ol>

  <div class="answers-section">
    <h4>Answer Options:</h4>
    <ul class="answers-list">
      {answers.map((ans) => (
        <li><strong>({ans.label})</strong> {ans.text} {ans.correct ? <span style="color: green; float: right;">&#10003;</span> : <span style="color: red; float: right;">&#10007;</span>}</li>
      ))}
    </ul>

    <div
      class="explanation-box"
      style="margin-top: 15px; padding: 15px; border: 1px solid #ccc; background-color: #f9f9f9; border-radius: 5px;"
    >
      <h5>Explanation:</h5>
      <p>{explanation}</p>
    </div>
  </div>
</div>