---
export interface FindingRubricItem {
  observation: string;
  mark: number;
}

export interface MediumCaseCard {
  questionNumber: number;
  history: string;
  imaging: string;
  maxMarks: number; // 6
  findings: FindingRubricItem[];
  diagnosis: string;
  diagnosisMarks: number; // 2
}

export interface Props {
  title?: string;
  cards?: MediumCaseCard[];
}

const defaultCards: MediumCaseCard[] = [
  {
    questionNumber: 1,
    history: "[Insert brief 1-sentence clinical history]",
    imaging: "[Insert modalities, sequences, and slice/image counts]",
    maxMarks: 6,
    findings: [
      { observation: "[Observation 1 / Primary anatomical abnormality]", mark: 1 },
      { observation: "[Observation 2 / Specific lesion characteristics or dimensions]", mark: 0.5 },
      { observation: "[Observation 3 / Surrounding structure involvement or secondary signs]", mark: 1 },
      { observation: "[Observation 4 / Relevant negative or secondary modifier]", mark: 0.5 },
    ],
    diagnosis: "[Insert primary diagnosis]",
    diagnosisMarks: 2,
  },
];

const { title = "Case Reporting Medium Case", cards = defaultCards } = Astro.props;

function findingsTotal(findings: FindingRubricItem[]): number {
  return findings.reduce((sum, f) => sum + f.mark, 0);
}
---

<main>
  <h1>{title}</h1>

  {cards.map((card) => (
    <div class="question-block mediumcase-card">
      <h2>Question Number: {card.questionNumber}</h2>

      <div class="card-field">
        <h3>History:</h3>
        <p>{card.history}</p>
      </div>

      <div class="card-field">
        <h3>Imaging:</h3>
        <p>{card.imaging}</p>
      </div>

      <div class="card-field">
        <h3>Maximum Marks:</h3>
        <p class="marks">{card.maxMarks}</p>
      </div>

      <textarea
        class="mediumcase-answer-input"
        rows="4"
        placeholder="Type your answer here..."
      ></textarea>

      <div class="rubric-section">
        <h3>Marking Rubric</h3>

        <div class="rubric-subsection">
          <h4>Findings <span class="rubric-total">(Total: {findingsTotal(card.findings)} marks)</span></h4>
          {card.findings.map((item, idx) => (
            <div class="rubric-row">
              <span class="rubric-bullet">&#8226;</span>
              <span class="rubric-finding">{item.observation}</span>
              <span class="rubric-marks">({item.mark})</span>
            </div>
          ))}
          <p class="rubric-note">*Ensure the total for Findings equals exactly 4 marks</p>
        </div>

        <div class="rubric-subsection">
          <div class="rubric-row rubric-diagnosis-row">
            <span class="rubric-criteria">Likely Diagnosis:</span>
            <span class="rubric-diagnosis">{card.diagnosis}</span>
            <span class="rubric-marks">({card.diagnosisMarks})</span>
          </div>
        </div>
      </div>
    </div>
  ))}
</main>

