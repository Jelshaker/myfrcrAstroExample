---
export interface RubricItem {
  point: string;
  mark: number; // e.g., 0.5
}

export interface SubQuestion {
  number: number; // e.g., 1.1, 1.2
  text: string;
  mark: string; // e.g., "Maximum of 2 marks"
  rubric: RubricItem[];
}

export interface PathologySAQCard {
  questionNumber: number;
  history: string;
  maxMarks: number; // 6
  subQuestions: SubQuestion[];
}

export interface Props {
  title?: string;
  timeTarget?: string;
  cards?: PathologySAQCard[];
}

const defaultCards: PathologySAQCard[] = [
  {
    questionNumber: 1,
    history: "[Insert 1-2 sentence clinical history or a specific disease topic]",
    maxMarks: 6,
    subQuestions: [
      {
        number: 1.1,
        text: "[Insert question text]",
        mark: "Maximum of 2 marks",
        rubric: [
          { point: "[Point 1]", mark: 0.5 },
          { point: "[Point 2]", mark: 0.5 },
        ],
      },
      {
        number: 1.2,
        text: "[Insert question text]",
        mark: "Maximum of 1 mark",
        rubric: [
          { point: "[Point 1]", mark: 0.5 },
        ],
      },
    ],
  },
  {
    questionNumber: 2,
    history: "[Insert 1-2 sentence clinical history or a specific disease topic]",
    maxMarks: 6,
    subQuestions: [
      {
        number: 2.1,
        text: "[Insert question text]",
        mark: "Maximum of 2 marks",
        rubric: [
          { point: "[Point 1]", mark: 0.5 },
          { point: "[Point 2]", mark: 0.5 },
          { point: "[Point 3]", mark: 0.5 },
          { point: "[Point 4]", mark: 0.5 },
        ],
      },
      {
        number: 2.2,
        text: "[Insert question text]",
        mark: "Maximum of 2 marks",
        rubric: [
          { point: "[Point 1]", mark: 0.5 },
          { point: "[Point 2]", mark: 0.5 },
          { point: "[Point 3]", mark: 0.5 },
          { point: "[Point 4]", mark: 0.5 },
        ],
      },
      {
        number: 2.3,
        text: "[Insert question text]",
        mark: "Maximum of 2 marks",
        rubric: [
          { point: "[Point 1]", mark: 0.5 },
          { point: "[Point 2]", mark: 0.5 },
          { point: "[Point 3]", mark: 0.5 },
          { point: "[Point 4]", mark: 0.5 },
        ],
      },
    ],
  },
];

const { title = "Pathology SAQ", timeTarget = "24 Marks (6 Marks Per Question)", cards = defaultCards } = Astro.props;
---

<main>
  <h1>{title}</h1>

  {cards.map((card) => (
    <div class="question-block pathology-saq-card">
      <h2>Question Number: {card.questionNumber}</h2>
      <div class="history-section">
        <h3>History/Lead-in:</h3>
        <p>{card.history}</p>
      </div>
      <p><strong>Maximum Marks:</strong> {card.maxMarks}</p>

      <div class="sub-questions">
        {card.subQuestions.map((sq) => (
          <div class="sub-question-block">
            <h4>Sub question {sq.number}:</h4>
            <p>{sq.text}</p>
            <textarea class="saq-answer-input" rows="3" placeholder="Type your answer here..."></textarea>
            <p class="mark-weighting"><strong>Mark:</strong> {sq.mark}</p>
            <div class="rubric-section">
              <h5>Rubric:</h5>
              <ul>
                {sq.rubric.map((item) => (
                  <li>- {item.point} ({item.mark})</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  ))}

  <footer class="pathology-saq-footer">
    <p><strong>Time Target:</strong> {timeTarget}</p>
  </footer>
</main>
