---
export interface PhysicsResource {
  title: string;
  description: string;
  href: string;
  badge?: string;
}

export interface Props {
  resource: PhysicsResource;
}

const { resource } = Astro.props;
const { title, description, href, badge } = resource;
---

<div class="physics-card">
  {badge && <span class="physics-badge">{badge}</span>}

  <div class="physics-card-header">
    <svg class="physics-icon" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10" />
      <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
      <line x1="12" y1="17" x2="12.01" y2="17" />
    </svg>
    <h3 class="physics-title">{title}</h3>
  </div>

  <p class="physics-description">{description}</p>

  <div class="physics-details">
    <div class="physics-detail-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <polyline points="14 2 14 8 20 8" />
        <line x1="16" y1="13" x2="8" y2="13" />
        <line x1="16" y1="17" x2="8" y2="17" />
        <polyline points="10 9 9 9 8 9" />
      </svg>
      <span>RCR Official Specimen Questions</span>
    </div>
    <div class="physics-detail-item">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span>Physics Module — Part 1 CR1</span>
    </div>
  </div>

  <a href={href} class="physics-cta" target="_blank" rel="noopener noreferrer">
    View Specimen Questions
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M7 17l9.2-9.2M17 17V7H7" />
    </svg>
  </a>
</div>

<hr class="question-divider" />

<div class="question-block">
  <h3 class="question-heading">### Question [Number]</h3>

  <p class="question-stem">
    <strong>Stem:</strong> Concerning/In [Insert Topic or Core Statement Here]:
  </p>

  <ol class="question-options" type="a">
    <li>[Statement 1]</li>
    <li>[Statement 2]</li>
    <li>[Statement 3]</li>
    <li>[Statement 4]</li>
    <li>[Statement 5]</li>
  </ol>

  <div class="answers-section">
    <h4>Answers & Explanations:</h4>
    <ul class="answers-list">
      <li><strong>(a) [True/False]:</strong> [Brief explanation of the physics principle or rule]</li>
      <li><strong>(b) [True/False]:</strong> [Brief explanation]</li>
      <li><strong>(c) [True/False]:</strong> [Brief explanation]</li>
      <li><strong>(d) [True/False]:</strong> [Brief explanation]</li>
      <li><strong>(e) [True/False]:</strong> [Brief explanation]</li>
    </ul>
  </div>
</div>
