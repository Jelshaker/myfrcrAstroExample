---
export interface ShortCaseCard {
  questionNumber: number;
  history: string;
  imaging: string;
  maxMarks: number; // 3
  diagnosis: string; // the "Likely Diagnosis" answer
}

export interface Props {
  title?: string;
  cards?: ShortCaseCard[];
}

const defaultCards: ShortCaseCard[] = [
  {
    questionNumber: 1,
    history: "[Insert brief 1-sentence history]",
    imaging: "[Insert modality, view/projection, and image count]",
    maxMarks: 3,
    diagnosis: "[Insert exact pathognomonic diagnosis]",
  },
];

const { title = "Case Reporting Short Case", cards = defaultCards } = Astro.props;
---

<main>
  <h1>{title}</h1>

  {cards.map((card) => (
    <div class="question-block shortcase-card">
      <h2>Question Number: {card.questionNumber}</h2>

      <div class="card-field">
        <h3>History:</h3>
        <p>{card.history}</p>
      </div>

      <div class="card-field">
        <h3>Imaging:</h3>
        <p>{card.imaging}</p>
      </div>

      <div class="card-field">
        <h3>Maximum Marks:</h3>
        <p class="marks">{card.maxMarks}</p>
      </div>

      <textarea
        class="shortcase-answer-input"
        rows="3"
        placeholder="Type your answer here..."
      ></textarea>

      <div class="rubric-section">
        <h3>Marking Rubric</h3>
        <div class="rubric-row">
          <span class="rubric-criteria">Likely Diagnosis:</span>
          <span class="rubric-diagnosis">{card.diagnosis}</span>
          <span class="rubric-marks">({card.maxMarks})</span>
        </div>
      </div>
    </div>
  ))}
</main>

