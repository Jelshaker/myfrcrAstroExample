---
export interface RubricItem {
  observation: string;
  mark: number;
}

export interface LongCaseCard {
  questionNumber: number;
  history: string;
  imaging: string;
  maxMarks: number; // 12
  findings: RubricItem[];
  diagnosis: string;
  diagnosisMarks: number; // 2
  differential: string;
  differentialMarks: number; // e.g., 0 or 1
  managementSteps: RubricItem[];
}

export interface Props {
  title?: string;
  cards?: LongCaseCard[];
}

const defaultCards: LongCaseCard[] = [
  {
    questionNumber: 1,
    history: "[Insert concise 1-sentence clinical history]",
    imaging: "[Insert multiple modalities, sequences, and slice/image counts]",
    maxMarks: 12,
    findings: [
      { observation: "[Primary lesion/mass characteristics and exact location]", mark: 1 },
      { observation: "[Vascular relationship, narrowing, or encasement]", mark: 0.5 },
      { observation: "[Nodal staging: specific lymphadenopathy sites]", mark: 1 },
      { observation: "[Secondary distant or structural abnormalities / bony remodelling]", mark: 1 },
      { observation: "[Critical relevant negative 1]", mark: 0.5 },
      { observation: "[Critical relevant negative 2]", mark: 0.5 },
    ],
    diagnosis: "[Insert primary/metastatic diagnosis]",
    diagnosisMarks: 2,
    differential: "[Insert relevant differential, or \"None\"]",
    differentialMarks: 0,
    managementSteps: [
      { observation: "[Actionable step 1: e.g., Further systemic staging with PET-CT]", mark: 1 },
      { observation: "[Actionable step 2: e.g., Image-guided tissue biopsy or urgent subspecialty referral]", mark: 1 },
    ],
  },
];

const { title = "Case Reporting Long Case", cards = defaultCards } = Astro.props;

function sumMarks(items: RubricItem[]): number {
  return items.reduce((sum, item) => sum + item.mark, 0);
}
---

<main>
  <h1>{title}</h1>

  {cards.map((card) => {
    const findingsTotal = sumMarks(card.findings);
    const managementTotal = sumMarks(card.managementSteps);
    const rubricTotal = findingsTotal + card.diagnosisMarks + card.differentialMarks + managementTotal;

    return (
      <div class="question-block longcase-card">
        <h2>Question Number: {card.questionNumber}</h2>

        <div class="card-field">
          <h3>History:</h3>
          <p>{card.history}</p>
        </div>

        <div class="card-field">
          <h3>Imaging:</h3>
          <p>{card.imaging}</p>
        </div>

        <div class="card-field">
          <h3>Maximum Marks:</h3>
          <p class="marks">{card.maxMarks}</p>
        </div>

        <textarea
          class="longcase-answer-input"
          rows="6"
          placeholder="Type your answer here..."
        ></textarea>

        <div class="rubric-section">
          <h3>Marking Rubric</h3>

          {/* Findings */}
          <div class="rubric-subsection">
            <h4>Findings <span class="rubric-total">(Subtotal: {findingsTotal} marks)</span></h4>
            {card.findings.map((item, idx) => (
              <div class="rubric-row">
                <span class="rubric-bullet">&#8226;</span>
                <span class="rubric-finding">{item.observation}</span>
                <span class="rubric-marks">({item.mark})</span>
              </div>
            ))}
            <p class="rubric-note">
              *Ensure the total for Findings balances perfectly with the remaining sections to equal exactly 12 marks total
            </p>
          </div>

          {/* Likely Diagnosis */}
          <div class="rubric-subsection">
            <div class="rubric-row">
              <span class="rubric-criteria">Likely Diagnosis:</span>
              <span class="rubric-diagnosis">{card.diagnosis}</span>
              <span class="rubric-marks">({card.diagnosisMarks})</span>
            </div>
          </div>

          {/* Differential Diagnosis */}
          <div class="rubric-subsection">
            <div class="rubric-row">
              <span class="rubric-criteria">Differential Diagnosis:</span>
              <span class="rubric-diagnosis">{card.differential}</span>
              <span class="rubric-marks">({card.differentialMarks})</span>
            </div>
          </div>

          {/* Further Investigation and Management */}
          <div class="rubric-subsection">
            <h4>Further Investigation and Management <span class="rubric-total">(Subtotal: {managementTotal} marks)</span></h4>
            {card.managementSteps.map((item, idx) => (
              <div class="rubric-row">
                <span class="rubric-bullet">&#8226;</span>
                <span class="rubric-finding">{item.observation}</span>
                <span class="rubric-marks">({item.mark})</span>
              </div>
            ))}
          </div>

          {/* Total */}
          <div class="rubric-total-row">
            <span class="rubric-criteria">Total:</span>
            <span class="rubric-marks">{rubricTotal} marks</span>
          </div>
        </div>
      </div>
    );
  })}
</main>

