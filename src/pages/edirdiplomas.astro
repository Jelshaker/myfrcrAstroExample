---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
---

<Layout title="EDiR Diplomas - MyFRCR.com" theme="edirdiplomas">
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            EDiR Diplomas
            <span class="hero-title-gradient">Topic-Specific Diploma Platforms</span>
          </h1>
          <p class="hero-description">
            Specialised diploma-level platforms covering specific subspecialties within the European Diploma in Radiology curriculum. Each platform is dedicated to a particular area, providing focused, in-depth revision content.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">Subspecialty Focus</p></div>
            <div class="stat-card"><p class="stat-card-text">Expert Content</p></div>
            <div class="stat-card"><p class="stat-card-text">DICOM Quality</p></div>
            <div class="stat-card"><p class="stat-card-text">ESR Aligned</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Diplomas Section -->
    <section class="section section-white">
      <div class="container">
        <h2 class="section-title text-center">Available Diploma Platforms</h2>
        <p class="section-subtitle">Specialised platforms for each subspecialty area of the EDiR diploma.</p>
        <div class="table-wrapper">
          <table class="table-custom">
            <thead>
              <tr>
                <th>Diploma</th>
                <th>Subspecialty</th>
                <th>Focus</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong>Abdominal / GI / GU</strong></td>
                <td>Abdominal Radiology</td>
                <td>GI, GU, and abdominal imaging</td>
              </tr>
              <tr>
                <td><strong>Breast</strong></td>
                <td>Breast Radiology</td>
                <td>Mammography, ultrasound, and breast MRI</td>
              </tr>
              <tr>
                <td><strong>Cardiovascular & Thoracic</strong></td>
                <td>Cardiothoracic Radiology</td>
                <td>Cardiac and chest imaging</td>
              </tr>
              <tr>
                <td><strong>Emergency</strong></td>
                <td>Emergency Radiology</td>
                <td>Acute and trauma imaging</td>
              </tr>
              <tr>
                <td><strong>Interventional</strong></td>
                <td>Interventional Radiology</td>
                <td>Image-guided procedures</td>
              </tr>
              <tr>
                <td><strong>Musculoskeletal</strong></td>
                <td>MSK Radiology</td>
                <td>Bone, joint, and soft tissue imaging</td>
              </tr>
              <tr>
                <td><strong>Neuroradiology & Head/Neck</strong></td>
                <td>Neuroradiology</td>
                <td>Brain, spine, and head/neck imaging</td>
              </tr>
              <tr>
                <td><strong>Paediatrics</strong></td>
                <td>Paediatric Radiology</td>
                <td>Imaging in children</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="info-box">
          <p>Each diploma platform provides focused, in-depth revision content specific to its subspecialty area, with full lossless DICOM images and expert-created cases.</p>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Why Choose EDiR Diploma Platforms?</h2>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Focused Content</h3>
            <p class="feature-desc">Deep, subspecialty-specific revision material for targeted preparation.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Expert Authors</h3>
            <p class="feature-desc">All content created by subspecialist consultant radiologists.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">DICOM Quality</h3>
            <p class="feature-desc">Full lossless images at diagnostic workstation quality.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Exam Simulation</h3>
            <p class="feature-desc">Authentic exam conditions with detailed feedback.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About EDiR Diplomas</h6>
            <h2 class="about-title">Specialised Diploma-Level Platforms</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              The EDiR Diploma platforms provide focused, subspecialty-specific revision resources for candidates preparing for the European Diploma in Radiology. Each platform is dedicated to a particular subspecialty area, offering in-depth coverage with expert-created content and full lossless DICOM images.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Comprehensive Coverage</h4>
                <p class="about-stat-desc">Eight subspecialty areas covered in depth.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert Content</h4>
                <p class="about-stat-desc">Created by consultant radiologists with subspecialty expertise.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myEDiRlogo lowercase.png" alt="EDiR Diplomas" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>