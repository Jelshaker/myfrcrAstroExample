---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRCR Part 2B - MyFRCR.com" theme="myfrcr">
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            FRCR Part
            <span class="hero-title-gradient">2B</span>
          </h1>
          <p class="hero-description">
            Master the FRCR Part 2B examination with comprehensive rapid reporting sessions and in-depth case discussions. Featuring full lossless DICOM images at diagnostic workstation quality with examiner-style marking and feedback.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">600+ Core Cases</p></div>
            <div class="stat-card"><p class="stat-card-text">Rapid Reporting Sessions</p></div>
            <div class="stat-card"><p class="stat-card-text">Full DICOM Quality</p></div>
            <div class="stat-card"><p class="stat-card-text">Examiner-Style Marking</p></div>
          </div>
          <div class="hero-actions">
            <a href="#pricing" class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">600+</div>
            <div class="stat-label">Core Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>1M</div>
            <div class="stat-label">DICOM Images</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Full</div>
            <div class="stat-label">Diagnostic Quality</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>FRCR Part 2B Revision</h2>
            <p>
              The FRCR Part 2B examination comprises two components: rapid reporting and case discussion/viva. Our comprehensive platform provides extensive practice material for both components, with full lossless DICOM images and examiner-style marking criteria to ensure realistic exam preparation.
            </p>
            <ul class="content-list">
              <li><strong>Rapid Reporting</strong> &mdash; Timed sessions mirroring the FRCR 2B rapid reporting format with instant feedback</li>
              <li><strong>Case Discussions</strong> &mdash; In-depth cases with examiner-style marking and detailed model answers</li>
              <li><strong>Full DICOM Quality</strong> &mdash; Diagnostic workstation quality images following RCR PACS guidelines</li>
              <li><strong>Examiner Feedback</strong> &mdash; Structured marking with criteria used by FRCR examiners</li>
            </ul>
          </div>
          <div>
            <div class="content-images grid-2x2">
              <img src="/assets/myfrcrlogo.png" alt="MyFRCR" />
              <img src="/assets/myABRcorelogo.png" alt="ABR Core" />
              <img src="/assets/myEDiRlogo lowercase.png" alt="EDiR" />
              <img src="/assets/myRCPSClogo.png" alt="RCPSC" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Components Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">FRCR 2B Exam Components</h2>
        <p class="section-subtitle">Comprehensive preparation for both components of the FRCR 2B examination.</p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Rapid Reporting</h3>
            <p class="feature-desc">Timed rapid reporting sessions with full DICOM images, mirroring the real exam format with instant performance feedback.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Case Discussions</h3>
            <p class="feature-desc">In-depth viva-style case discussions with structured examiner marking and comprehensive model answers.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">All Subspecialties</h3>
            <p class="feature-desc">Cases across chest, MSK, neuroradiology, GI, GU, breast, cardiac, and paediatric radiology.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Performance Analytics</h3>
            <p class="feature-desc">Detailed performance tracking with subspecialty breakdowns to identify areas for improvement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your FRCR Part 2B examination</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">£120</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">2 months of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">600+ Core Cases</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Rapid Reporting Sessions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Full Lossless DICOM</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Examiner-Style Marking</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice & Progress Tracking</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About FRCR Part 2B</h6>
            <h2 class="about-title">Comprehensive 2B Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our FRCR Part 2B resource is designed to provide comprehensive preparation for both the rapid reporting and case discussion components of the exam. With hundreds of cases featuring full lossless DICOM images and examiner-style marking criteria, you can build the speed, accuracy, and confidence needed to succeed.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">600+ Cases</h4>
                <p class="about-stat-desc">Extensive case library covering all subspecialties and exam components.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Enterprise Infrastructure</h4>
                <p class="about-stat-desc">Custom DICOM viewer powered by enterprise cloud infrastructure.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">RCR Guidelines Compliant</h4>
                <p class="about-stat-desc">Following international PACS display guidelines for diagnostic workstations.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">100% Human-Made</h4>
                <p class="about-stat-desc">All clinical cases authored by expert human consultant radiologists.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myfrcrlogo white background.png" alt="myFRCR Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>