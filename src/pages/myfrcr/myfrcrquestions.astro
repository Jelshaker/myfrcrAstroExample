---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import PhysicsCard from '../../components/questions/myfrcrphysics.astro';
import QuestionCard from '../../components/questioncard.astro';
import SBA from '../../components/questions/SBA.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRCR Questions – myFRCR - FRCR Exam - MyFRCR.com" theme="myfrcr">
  <Navbar />
  <Subnav links={[
    { label: 'Part A Physics', href: '/myfrcr/myfrcrpart1a' },
    { label: 'Part 2A', href: '/myfrcr/myfrcrpart2a' },
    { label: 'Part 2B Shorts & Long Cases', href: '/myfrcr/myfrcrpart2b' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            FRCR Questions
            <span class="hero-title-gradient">Physics & Specimen Resources</span>
          </h1>
          <p class="hero-description">
            Access official RCR specimen questions and comprehensive physics resources to prepare for your FRCR Part 1 CR1 examination.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">RCR Official Specimen</p></div>
            <div class="stat-card"><p class="stat-card-text">Physics Module Focus</p></div>
            <div class="stat-card"><p class="stat-card-text">Part 1 CR1</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">RCR</div>
            <div class="stat-label">Official Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Physics</div>
            <div class="stat-label">Module Focus</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Part 1</div>
            <div class="stat-label">CR1 Exam</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Free Access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Physics Card Section -->
    <section class="section section-white" id="physics-resources">
      <div class="container">
        <h2 class="section-title text-center">Physics Specimen Questions</h2>
        <p class="section-subtitle">Official RCR FRCR Part 1 CR1 Physics Module specimen questions</p>

        <div class="cards-grid">
          <PhysicsCard
            resource={{
              title: 'FRCR Part 1 Physics',
              description: 'Official RCR specimen questions for the FRCR Part 1 CR1 Physics module. These questions cover the core physics principles relevant to clinical radiology, including radiation physics, imaging equipment, radiation safety, and quality assurance.',
              href: 'https://www.rcr.ac.uk/exams-training/rcr-exams/clinical-radiology-exams/frcr-part-1-radiology-cr1/frcr-part-1-radiology-cr1-specimen-questions-physics-module/',
              badge: 'Official RCR Resource',
            }}
          />
        </div>
      </div>
    </section>

    <!-- SBA Sample Question Section -->
    <section class="section section-gray" id="sba-sample">
      <div class="container">
        <h2 class="section-title text-center">Sample SBA Question</h2>
        <p class="section-subtitle">Live practice question in the Single Best Answer format with answer and explanation</p>

        <div class="questions-grid">
          <SBA
            question={{
              number: 1,
              stem: 'Concerning/In [Insert Topic or Core Statement Here]:',
              statements: [
                { label: 'a', text: '[Statement 1]' },
                { label: 'b', text: '[Statement 2]' },
                { label: 'c', text: '[Statement 3]' },
                { label: 'd', text: '[Statement 4]' },
                { label: 'e', text: '[Statement 5]' },
              ],
              answers: [
                { label: 'a', text: 'Incorrect', correct: false },
                { label: 'b', text: 'Incorrect', correct: false },
                { label: 'c', text: 'Correct Best Answer', correct: true },
                { label: 'd', text: 'Incorrect', correct: false },
                { label: 'e', text: 'Incorrect', correct: false },
              ],
              explanation: '[Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
            }}
          />
        </div>
      </div>
    </section>
  </main>

  
