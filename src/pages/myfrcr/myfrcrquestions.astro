---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import PhysicsCard from '../../components/questions/myfrcrphysics.astro';
import QuestionCard from '../../components/questioncard.astro';
import SBA from '../../components/questions/SBA.astro';
import CoreCases from '../../components/questions/corecases.astro';
import FRCRShortCase from '../../components/questions/frcrshort.astro';
import FRCRLongCase from '../../components/questions/frcrlong.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRCR Questions – myFRCR - FRCR Exam - MyFRCR.com" theme="myfrcr">
  <Navbar />
  <Subnav links={[
    { label: 'Part A Physics', href: '/myfrcr/myfrcrpart1a' },
    { label: 'Part 2A', href: '/myfrcr/myfrcrpart2a' },
    { label: 'Part 2B Shorts & Long Cases', href: '/myfrcr/myfrcrpart2b' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            Questions
            <span class="hero-title-gradient">Physics & Specimen Resources</span>
          </h1>
          <p class="hero-description">
            Access official RCR specimen questions and comprehensive physics resources to prepare for your FRCR Part 1 CR1 examination.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">RCR Official Specimen</p></div>
            <div class="stat-card"><p class="stat-card-text">Physics Module Focus</p></div>
            <div class="stat-card"><p class="stat-card-text">Part 1 CR1</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">RCR</div>
            <div class="stat-label">Official Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Physics</div>
            <div class="stat-label">Module Focus</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Part 1</div>
            <div class="stat-label">CR1 Exam</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Free Access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== FRCR PHYSICS SECTION ==================== -->
    <section class="section section-physics" id="frcr-physics">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-physics">Part 1 CR1</span>
          <h2 class="section-title text-center">FRCR Physics</h2>
          <p class="section-subtitle">
            Master the physics principles tested in the FRCR Part 1 CR1 examination. Practice with official RCR specimen Single Best Answer questions covering radiation physics, imaging equipment, and safety.
          </p>
        </div>
        <div class="reference-links" style="display: flex; justify-content: center; margin: 1.5rem 0;">
          <a href="https://www.rcr.ac.uk/exams-training/rcr-exams/clinical-radiology-exams/frcr-part-1-radiology-cr1/frcr-part-1-radiology-cr1-specimen-questions-physics-module/" target="_blank" rel="noopener noreferrer"
             style="display: inline-block; font-size: 1.15rem; font-weight: 700; padding: 0.9rem 2rem; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
            📄 Official RCR Specimen – Physics Module &rarr;
          </a>
        </div>
        <PhysicsCard
          resource={{
            title: 'FRCR Physics Specimen Questions',
            description: 'Official RCR specimen questions for the FRCR Part 1 CR1 Physics module. Practice with Single Best Answer format questions covering key physics principles.',
            href: '#',
            badge: 'RCR Official',
          }}
        />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== FRCR 2A SECTION ==================== -->
    <section class="section section-2a" id="frcr-2a">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-2a">Part 2A</span>
          <h2 class="section-title text-center">FRCR 2A</h2>
          <p class="section-subtitle">
            Prepare for the FRCR Part 2A examination with Single Best Answer questions covering radiological anatomy, disease patterns, and clinical radiology core knowledge.
          </p>
        </div>
        <div class="reference-links" style="display: flex; justify-content: center; margin: 1.5rem 0;">
          <a href="https://www.rcr.ac.uk/exams-training/rcr-exams/clinical-radiology-exams/frcr-part-2a-radiology-cr2a/frcr-part-2a-radiology-cr2a-specimen-questions/" target="_blank" rel="noopener noreferrer"
             style="display: inline-block; font-size: 1.15rem; font-weight: 700; padding: 0.9rem 2rem; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
            📄 Official RCR Specimen – Part 2A &rarr;
          </a>
        </div>
        <SBA />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== FRCR 2B SHORT CASES SECTION ==================== -->
    <section class="section section-2b-shorts" id="frcr-2b-shorts">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-2b">Part 2B</span>
          <h2 class="section-title text-center">FRCR 2B Short Cases</h2>
          <p class="section-subtitle">
            Test your rapid reporting skills with short case scenarios covering a wide range of pathologies. Each case includes clinical history, imaging metadata, and a structured candidate response interface for observations and findings.
          </p>
        </div>
        <div class="reference-links" style="display: flex; justify-content: center; margin: 1.5rem 0;">
          <a href="https://www.rcr.ac.uk/exams-training/rcr-exams/clinical-radiology-exams/frcr-part-2b-radiology-cr2b/frcr-part-2b-radiology-cr2b-scoring-system/#EGSH" target="_blank" rel="noopener noreferrer"
             style="display: inline-block; font-size: 1.15rem; font-weight: 700; padding: 0.9rem 2rem; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
            📄 Official RCR – Part 2B Scoring System &rarr;
          </a>
        </div>
        <FRCRShortCase />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== FRCR 2B LONG CASES SECTION ==================== -->
    <section class="section section-2b-longs" id="frcr-2b-longs">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-2b">Part 2B</span>
          <h2 class="section-title text-center">FRCR 2B Long Cases</h2>
          <p class="section-subtitle">
            Test your reporting skills with complete long case scenarios covering chest, musculoskeletal, gastrointestinal, neurological, and paediatric imaging. Each case includes clinical history, full imaging findings with a structured marking rubric.
          </p>
        </div>
        <div class="reference-links" style="display: flex; justify-content: center; margin: 1.5rem 0;">
          <a href="https://www.rcr.ac.uk/exams-training/rcr-exams/exam-help-guidance/guidance-on-image-based-exam-delivery/" target="_blank" rel="noopener noreferrer"
             style="display: inline-block; font-size: 1.15rem; font-weight: 700; padding: 0.9rem 2rem; background: linear-gradient(135deg, #2563eb, #3b82f6); color: #fff; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
            📄 Official RCR – Image-Based Exam Guidance &rarr;
          </a>
        </div>
        <FRCRLongCase />
      </div>
    </section>
  </main>

  
</Layout>