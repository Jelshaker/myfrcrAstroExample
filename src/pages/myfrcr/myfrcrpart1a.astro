---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRCR Part A Physics - MyFRCR.com" theme="myfrcr">
  <Navbar />
  <Subnav links={[
    { label: 'Part A Physics', href: '/myfrcr/myfrcrpart1a' },
    { label: 'Part 2A', href: '/myfrcr/myfrcrpart2a' },
    { label: 'Part 2B Shorts & Long Cases', href: '/myfrcr/myfrcrpart2b' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            FRCR Part A
            <span class="hero-title-gradient">Physics</span>
          </h1>
          <p class="hero-description">
            Master the FRCR Physics curriculum with comprehensive questions and detailed explanations. Covering radiation physics, imaging physics, nuclear medicine, and radiation safety — all crafted by experienced consultant radiologists and medical physicists.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">Full Physics Curriculum</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
            <div class="stat-card"><p class="stat-card-text">RCR Guidelines Compliant</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Expert-Created</p></div>
          </div>
          <div class="hero-actions">
            <a href="#pricing" class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">1,000+</div>
            <div class="stat-label">Physics Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Complete</div>
            <div class="stat-label">Curriculum Coverage</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist & Physicist-Created</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Detailed</div>
            <div class="stat-label">Worked Explanations</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>FRCR Part A Physics Revision</h2>
            <p>
              The FRCR Part A Physics examination is a rigorous test of your understanding of the physical principles underlying modern radiology. Our comprehensive question bank covers every topic in the FRCR Physics curriculum, from basic radiation physics to advanced imaging modalities, all with detailed worked explanations to deepen your understanding.
            </p>
            <ul class="content-list">
              <li><strong>Radiation Physics</strong> &mdash; Atomic structure, radioactivity, X-ray production and interaction with matter</li>
              <li><strong>Imaging Physics</strong> &mdash; Radiography, fluoroscopy, CT, MRI, ultrasound and nuclear medicine physics</li>
              <li><strong>Radiation Protection</strong> &mdash; Dosimetry, shielding, legislation and safe practice</li>
              <li><strong>Image Quality</strong> &mdash; Contrast, resolution, noise, artefact recognition and optimisation</li>
            </ul>
          </div>
          <div>
            <div class="content-images grid-2x2">
              <img src="/assets/myfrcrlogo.png" alt="MyFRCR" />
              <img src="/assets/myABRcorelogo.png" alt="ABR Core" />
              <img src="/assets/myEDiRlogo lowercase.png" alt="EDiR" />
              <img src="/assets/myRCPSClogo.png" alt="RCPSC" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Topics Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Physics Topics Covered</h2>
        <p class="section-subtitle">Comprehensive coverage of the entire FRCR Part A Physics syllabus.</p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Radiation Physics</h3>
            <p class="feature-desc">Atomic and nuclear physics, X-ray production, spectra, beam quality and filtration.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Imaging Modalities</h3>
            <p class="feature-desc">CT, MRI, ultrasound, nuclear medicine and fluoroscopy physics in depth.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Radiation Protection</h3>
            <p class="feature-desc">Dosimetry, biological effects, legislation, shielding design and monitoring.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Image Quality & Artefacts</h3>
            <p class="feature-desc">Contrast, resolution, noise, artefacts and quality assurance testing.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your FRCR Part A Physics examination</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">£10</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">3 months of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">1,000+ Physics Questions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Full Curriculum Coverage</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Detailed Worked Explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">RCR Physics Syllabus Aligned</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice & Progress Tracking</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About FRCR Part A Physics</h6>
            <h2 class="about-title">Comprehensive Physics Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our FRCR Part A Physics resource is designed to provide thorough coverage of the RCR Physics curriculum. With hundreds of carefully crafted questions and detailed explanations, you can build a deep understanding of the physical principles that underpin modern radiology practice.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">1,000+ Questions</h4>
                <p class="about-stat-desc">Comprehensive question bank covering every physics topic in the FRCR syllabus.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by consultant radiologists and medical physicists.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">RCR Syllabus Aligned</h4>
                <p class="about-stat-desc">Structured to match the current RCR Physics curriculum requirements.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Detailed Explanations</h4>
                <p class="about-stat-desc">Every question includes a full worked explanation to reinforce learning.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myfrcrlogo white background.png" alt="myFRCR Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>