---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';

const examPackets = [
  // EBCR - Cardiac
  { body: 'EBCR', specialty: 'Cardiac', module: 'Cardiac', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EBCR', specialty: 'Cardiac', module: 'Cardiac CORE', bundleSize: 3, questionType: 'CORE', numQuestions: 2, cost: '€10', costValue: 10 },
  // EDER - Emergency
  { body: 'EDER', specialty: 'Emergency', module: 'Emergency', bundleSize: 3, questionType: 'MCQ', numQuestions: 20, cost: '€10', costValue: 10 },
  { body: 'EDER', specialty: 'Emergency', module: 'Emergency Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDGAR - GI HPB
  { body: 'EDGAR', specialty: 'GI HPB', module: 'GI HPB', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDGAR', specialty: 'GI HPB', module: 'GI HPB Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // ESHNR - H&N
  { body: 'ESHNR', specialty: 'H&N', module: 'Head & Neck', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'ESHNR', specialty: 'H&N', module: 'Head & Neck Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EBNR - Neuro
  { body: 'EBNR', specialty: 'Neuro', module: 'Module 1', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EBNR', specialty: 'Neuro', module: 'Module 2', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EBNR', specialty: 'Neuro', module: 'Module 3', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EBNR', specialty: 'Neuro', module: 'Module 4', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EBNR', specialty: 'Neuro', module: 'Final Written', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiPNR - Paediatric Neuroradiology
  { body: 'EDiPNR', specialty: 'Paediatric Neuroradiology', module: 'Module 1', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiPNR', specialty: 'Paediatric Neuroradiology', module: 'Module 2', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiPNR', specialty: 'Paediatric Neuroradiology', module: 'Module 3', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiPNR', specialty: 'Paediatric Neuroradiology', module: 'Final Written', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiSR - Spinal Radiology
  { body: 'EDiSR', specialty: 'Spinal Radiology', module: 'Module 1', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiSR', specialty: 'Spinal Radiology', module: 'Module 2', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiSR', specialty: 'Spinal Radiology', module: 'Final Oral', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiINR - Interventional Neuroradiology
  { body: 'EDiINR', specialty: 'Interventional Neuroradiology', module: 'Module 1', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiINR', specialty: 'Interventional Neuroradiology', module: 'Module 2', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiINR', specialty: 'Interventional Neuroradiology', module: 'Module 3', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiINR', specialty: 'Interventional Neuroradiology', module: 'Final Written', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiHNNR - Neuro H&N
  { body: 'EDiHNNR', specialty: 'Neuro H&N', module: 'Module 1', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiHNNR', specialty: 'Neuro H&N', module: 'Module 2', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDiHNNR', specialty: 'Neuro H&N', module: 'Final Written', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiPR - Paediatrics
  { body: 'EDiPR', specialty: 'Paediatrics', module: 'Module Chest', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EDiPR', specialty: 'Paediatrics', module: 'Module Abdo', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EDiPR', specialty: 'Paediatrics', module: 'Module MSK', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EDiPR', specialty: 'Paediatrics', module: 'Module Neuro', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EDiPR', specialty: 'Paediatrics', module: 'Module Final', bundleSize: 3, questionType: 'Short Cases', numQuestions: 10, cost: '€10', costValue: 10 },
  // ESTI - Thoracic
  { body: 'ESTI', specialty: 'Thoracic', module: 'Thoracic', bundleSize: 3, questionType: 'MCQ', numQuestions: 20, cost: '€10', costValue: 10 },
  { body: 'ESTI', specialty: 'Thoracic', module: 'Thoracic Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 6, cost: '€10', costValue: 10 },
  // EDiUR - Urology
  { body: 'EDiUR', specialty: 'Urology', module: 'Urology MCQ', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EDiUR', specialty: 'Urology', module: 'Urology Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 4, cost: '€10', costValue: 10 },
  { body: 'EDiUR', specialty: 'Urology', module: 'Urology CORE', bundleSize: null, questionType: 'CORE', numQuestions: 4, cost: null, costValue: null },
  // EDBI - Breast
  { body: 'EDBI', specialty: 'Breast', module: 'Breast', bundleSize: 3, questionType: 'MCQ', numQuestions: 30, cost: '€10', costValue: 10 },
  { body: 'EDBI', specialty: 'Breast', module: 'Breast Short Cases', bundleSize: 3, questionType: 'Short Cases', numQuestions: 15, cost: '€10', costValue: 10 },
  // EBIR - Interventional
  { body: 'EBIR', specialty: 'Interventional', module: 'Interventional', bundleSize: 3, questionType: 'MCQ', numQuestions: 50, cost: '€10', costValue: 10 },
  { body: 'EBIR', specialty: 'Interventional', module: 'Interventional CORE', bundleSize: 3, questionType: 'CORE', numQuestions: 10, cost: '€10', costValue: 10 },
  // EDiMSK - MSK
  { body: 'EDiMSK', specialty: 'MSK', module: 'MSK', bundleSize: 3, questionType: 'MCQ', numQuestions: 40, cost: '€10', costValue: 10 },
  { body: 'EDiMSK', specialty: 'MSK', module: 'MSK CORE', bundleSize: 3, questionType: 'CORE', numQuestions: 2, cost: '€10', costValue: 10 },
];

// Group by exam body
const groupedByBody: Record<string, typeof examPackets> = {};
for (const p of examPackets) {
  if (!groupedByBody[p.body]) {
    groupedByBody[p.body] = [];
  }
  groupedByBody[p.body].push(p);
}

const bodyInfo: Record<string, { name: string, id: string }> = {
  'EBCR': { name: 'European Board of Cardiovascular Radiology', id: 'ebcr' },
  'EDER': { name: 'European Diploma in Emergency Radiology', id: 'eder' },
  'EDGAR': { name: 'European Diploma in Gastrointestinal and Abdominal Radiology', id: 'edgar' },
  'ESHNR': { name: 'European Society of Head and Neck Radiology', id: 'eshnr' },
  'EBNR': { name: 'European Board of Neuroradiology', id: 'ebnr' },
  'EDiPNR': { name: 'European Diploma in Paediatric Neuroradiology', id: 'edipnr' },
  'EDiSR': { name: 'European Diploma in Spinal Radiology', id: 'edisr' },
  'EDiINR': { name: 'European Diploma in Interventional Neuroradiology', id: 'ediinr' },
  'EDiHNNR': { name: 'European Diploma in Neuro Head & Neck Radiology', id: 'edihnnr' },
  'EDiPR': { name: 'European Diploma in Paediatric Radiology', id: 'edipr' },
  'ESTI': { name: 'European Society of Thoracic Imaging', id: 'esti' },
  'EDiUR': { name: 'European Diploma in Uroradiology', id: 'ediur' },
  'EDBI': { name: 'European Diploma in Breast Imaging', id: 'edbi' },
  'EBIR': { name: 'European Board of Interventional Radiology', id: 'ebir' },
  'EDiMSK': { name: 'European Diploma in Musculoskeletal Radiology', id: 'edimsk' },
};
---

<Layout title="EDiR Diploma Pricing – Individual Exam Packets – MyFRCR.com" theme="edirdiplomas">
  <Navbar />
  <Subnav links={[
    { label: 'EBCR', href: '/edir_diplomas/edir_diploma_pricing#ebcr' },
    { label: 'EDER', href: '/edir_diplomas/edir_diploma_pricing#eder' },
    { label: 'EDGAR', href: '/edir_diplomas/edir_diploma_pricing#edgar' },
    { label: 'ESHNR', href: '/edir_diplomas/edir_diploma_pricing#eshnr' },
    { label: 'EBNR', href: '/edir_diplomas/edir_diploma_pricing#ebnr' },
    { label: 'EDiPNR', href: '/edir_diplomas/edir_diploma_pricing#edipnr' },
    { label: 'EDiSR', href: '/edir_diplomas/edir_diploma_pricing#edisr' },
    { label: 'EDiINR', href: '/edir_diplomas/edir_diploma_pricing#ediinr' },
    { label: 'EDiHNNR', href: '/edir_diplomas/edir_diploma_pricing#edihnnr' },
    { label: 'EDiPR', href: '/edir_diplomas/edir_diploma_pricing#edipr' },
    { label: 'ESTI', href: '/edir_diplomas/edir_diploma_pricing#esti' },
    { label: 'EDiUR', href: '/edir_diplomas/edir_diploma_pricing#ediur' },
    { label: 'EDBI', href: '/edir_diplomas/edir_diploma_pricing#edbi' },
    { label: 'EBIR', href: '/edir_diplomas/edir_diploma_pricing#ebir' },
    { label: 'EDiMSK', href: '/edir_diplomas/edir_diploma_pricing#edimsk' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            EDiR Diploma Exam Packets
            <span class="hero-title-gradient">Individual Exam Packets for Targeted Preparation</span>
          </h1>
          <p class="hero-description">
            Purchase individual exam packets for each EDiR diploma platform. Each packet is sold separately — no bundling or combining of exams. Select the specific exam packets you need for focused, subspecialty-specific preparation.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">Individual Exam Packets</p></div>
            <div class="stat-card"><p class="stat-card-text">Per Packet Pricing</p></div>
            <div class="stat-card"><p class="stat-card-text">No Bundling Required</p></div>
            <div class="stat-card"><p class="stat-card-text">Subspecialty Focus</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Tables Section -->
    <section class="section section-white">
      <div class="container">
        <h2 class="section-title text-center">All Diploma Exam Packets</h2>
        <p class="section-subtitle">Each row is an individual exam packet available for separate purchase. Select only the packets you need for your preparation.</p>

        {
          Object.entries(groupedByBody).map(([body, packets]) => (
            <section id={bodyInfo[body].id} style={{ scrollMarginTop: '7rem' }}>
              <div class="diploma-header">
                <h3 class="diploma-body-code">{body}</h3>
                <p class="diploma-body-name">{bodyInfo[body].name}</p>
              </div>
              <div class="table-wrapper">
                <table class="table-custom packet-table">
                  <thead>
                    <tr>
                      <th>Module / Exam Packet</th>
                      <th>Question Type</th>
                      <th>Questions per Packet</th>
                      <th>Packets per Bundle</th>
                      <th>Cost per Packet</th>
                      <th>Action</th>
                    </tr>
                  </thead>
                  <tbody>
                    {packets.map((p) => (
                      <tr>
                        <td><strong>{p.module}</strong></td>
                        <td><span class="badge badge-qtype">{p.questionType}</span></td>
                        <td>{p.numQuestions}</td>
                        <td>{p.bundleSize ? `${p.bundleSize} exam packets` : 'TBC'}</td>
                        <td class="cost-cell">{p.cost || 'TBC'}</td>
                        <td>
                          <button class="btn btn-sm btn-buy" disabled={!p.cost}>
                            {p.cost ? 'Buy Now' : 'Coming Soon'}
                          </button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          ))
        }

        <div class="info-box" style="margin-top: 3rem;">
          <p><strong>Important:</strong> Each exam packet is sold as an individual product. You can purchase as many or as few packets as you need. There is no requirement to purchase multiple packets together. All packets within a bundle are identical in format and are designed for repeated practice sessions.</p>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About Exam Packet Pricing</h6>
            <h2 class="about-title">Individual Exam Packets — Your Choice</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our diploma platforms offer individual exam packets that you can purchase separately. Each packet contains a specific number of questions of a given type (MCQ, Short Cases, or CORE) for a particular module. This allows you to tailor your preparation exactly to your needs without paying for content you don't require.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Individual Purchase</h4>
                <p class="about-stat-desc">Buy only the exam packets you need — no forced bundles or combinations.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">€10 Per Packet</h4>
                <p class="about-stat-desc">Standard pricing across all diploma platforms for maximum affordability.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">3 Packets per Bundle</h4>
                <p class="about-stat-desc">Each bundle includes 3 exam packets of the same type for repeated practice.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Subspecialty Coverage</h4>
                <p class="about-stat-desc">Focused content across all major radiology subspecialties.</p>
              </div>
            </div>
            <a href={`${import.meta.env.BASE_URL}contact`} class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src={`${import.meta.env.BASE_URL}assets/myEDiRlogo lowercase.png`} alt="EDiR Diplomas" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .diploma-header {
    margin-bottom: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-gray-200);
  }

  .diploma-body-code {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-gray-900);
    margin-bottom: 0.25rem;
  }

  .diploma-body-name {
    font-size: 0.95rem;
    color: var(--color-gray-500);
  }

  .packet-table th {
    white-space: nowrap;
  }

  .packet-table td {
    vertical-align: middle;
  }

  .badge-qtype {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #dbeafe;
    color: #1e40af;
  }

  .cost-cell {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-gray-900);
  }

  .btn-buy {
    background: var(--color-blue-600);
    color: white;
    border: none;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-md);
    font-weight: 600;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-buy:hover:not(:disabled) {
    background: #1d4ed8;
  }

  .btn-buy:disabled {
    background: var(--color-gray-200);
    color: var(--color-gray-400);
    cursor: not-allowed;
  }

  section[id] {
    scroll-margin-top: 7rem;
  }
</style>