---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar.astro';
import Footer from '../components/footer.astro';
---

<Layout title="ABR Core Exam - MyFRCR.com">
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            ABR Core Exam Preparation
            <span class="hero-title-gradient">American Board of Radiology</span>
          </h1>
          <p class="hero-description">
            Master the ABR Core examination with authentic, expert-created content designed to mirror the ABR exam format. Access a comprehensive suite of clinically-oriented cases featuring full lossless DICOM images at diagnostic workstation quality following ACR guidelines. Every question and answer is meticulously crafted by experienced radiologists.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">10,000+ SBA Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">600+ Core Cases</p></div>
            <div class="stat-card"><p class="stat-card-text">1M+ DICOM Images</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Radiologist-Created</p></div>
          </div>
          <div class="hero-actions">
            <a href="#pricing" class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">10,000+</div>
            <div class="stat-label">SBA Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">600+</div>
            <div class="stat-label">CORE Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>1M</div>
            <div class="stat-label">DICOM Images</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>500GB</div>
            <div class="stat-label">Medical Imaging</div>
          </div>
        </div>
      </div>
    </section>

    <!-- What is ABR Core Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>What is ABR Core Exam Preparation?</h2>
            <p>
              ABRcore.com is the most comprehensive and extensive revision resource available for the American Board of Radiology Core exam, offered both online and in print. The unprecedented scale of the database allows for complete coverage of the ABR curriculum across all subspecialties and exam components. Thousands of high-quality image studies are integrated into a vast array of clinically-oriented cases and rapid-fire sessions, ensuring you are prepared for both common presentations and the rare, complex cases that test your clinical acumen.
            </p>
            <ul class="content-list">
              <li><strong>Full Lossless DICOM Images</strong> &mdash; Diagnostic workstation quality following ACR PACS guidelines</li>
              <li><strong>100% Radiologist-Created</strong> &mdash; Expert consultant radiologists &ndash; zero AI cases</li>
              <li><strong>Complete Coverage of the Curriculum</strong> &mdash; Every subspecialty across thousands of high-quality questions</li>
              <li><strong>Realistic Exam Simulation</strong> &mdash; Authentic conditions with examiner-style feedback</li>
            </ul>
          </div>
          <div>
            <div class="content-images grid-2x2">
              <img src="/assets/myABRcorelogo.png" alt="ABR Core" />
              <img src="/assets/myfrcrlogo.png" alt="MyFRCR" />
              <img src="/assets/myEDiRlogo lowercase.png" alt="EDiR" />
              <img src="/assets/myRCPSClogo.png" alt="RCPSC" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CORE Cases Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Clinically Oriented Reasoning Evaluation (CORE) Cases</h2>
        <p class="section-subtitle">
          The CORE cases serve as the backbone of the ABR preparation, simulating the high difficulty and critical components of the examination. These cases are designed to test your clinical reasoning through a structured exam delivery&mdash;from initial image interpretation and differential diagnosis to the most appropriate final management decisions.
        </p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Multimodal Integration</h3>
            <p class="feature-desc">Seamlessly transition between radiographs, CT, and MRI to evaluate pathology just as in the real exam.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Curriculum-Aligned Topics</h3>
            <p class="feature-desc">Each case is mapped to the ABR exam blueprint, covering all major subspecialties and domains.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Diagnostic Precision</h3>
            <p class="feature-desc">Using our lossless DICOM viewer, identify critical findings crucial for scoring high marks.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Exam Simulation</h3>
            <p class="feature-desc">Practice within an interface that mirrors the official ABR platform with authentic marking schemes.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Subspecialties Section -->
    <section class="offer-section">
      <div class="container">
        <div class="text-center">
          <div class="offer-header" style="justify-content: center;">
            <span>Subspecialties Covered</span>
          </div>
          <h2 class="offer-title">Complete ABR Curriculum Coverage</h2>
          <p class="section-subtitle">Comprehensive coverage across all ABR Core exam domains and subspecialties.</p>
        </div>
        <div class="subspecialty-grid" style="max-width: 48rem; margin: 0 auto;">
          <div class="subspecialty-item">Breast Imaging</div>
          <div class="subspecialty-item">Cardiac Radiology</div>
          <div class="subspecialty-item">Chest Radiology</div>
          <div class="subspecialty-item">Gastrointestinal Radiology</div>
          <div class="subspecialty-item">Genitourinary Radiology</div>
          <div class="subspecialty-item">Head and Neck Radiology</div>
          <div class="subspecialty-item">Interventional Radiology</div>
          <div class="subspecialty-item">Musculoskeletal Radiology</div>
          <div class="subspecialty-item">Neuroradiology</div>
          <div class="subspecialty-item">Nuclear Radiology</div>
          <div class="subspecialty-item">Pediatric Radiology</div>
          <div class="subspecialty-item">Ultrasound</div>
          <div class="subspecialty-item">Vascular Radiology</div>
          <div class="subspecialty-item">Emergency Radiology</div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your ABR Core Exam</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">$100</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">31 days of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">10,000+ SBA Questions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">600+ Full Core Questions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Examiner-style marking and explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Full diagnostic workstation quality DICOM Viewer</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About ABRcore.com</h6>
            <h2 class="about-title">Why ABRcore Leads ABR Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              ABRcore.com is the premier platform for the American Board of Radiology Core exam, offering an extensive database of authentic CORE cases, Short cases, and MRQs. Our commitment to expert-created content with full lossless DICOM quality ensures candidates receive genuine exam preparation that aligns with ACR standards.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Thousands of DICOM Studies</h4>
                <p class="about-stat-desc">A vast library of radiographs, CT, and MRI studies delivered in full lossless DICOM format.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Enterprise Infrastructure</h4>
                <p class="about-stat-desc">Custom DICOM viewer powered by enterprise cloud infrastructure.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">ACR Guidelines Compliant</h4>
                <p class="about-stat-desc">Following international PACS display guidelines for diagnostic workstations.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">100% Human-Made</h4>
                <p class="about-stat-desc">All clinical cases authored by expert human consultant radiologists.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myABRcorelogo.png" alt="ABR Core Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>