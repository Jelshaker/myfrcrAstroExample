---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import MRQ from '../../components/questions/MRQ.astro';
import SBA from '../../components/questions/SBA.astro';
import Shortcases, { type shortcasesquestion } from '../../components/questions/shortcases.astro';
import Corecases, { type corecasesquestion } from '../../components/questions/corecases.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="EDiR Questions – myEDiR - EDiR Exam - MyFRCR.com" theme="edir">
  <Navbar />
  <Subnav links={[
    { label: 'MCQ', href: '/edir/edir_mcq' },
    { label: 'Short Cases', href: '/edir/edir_shortcases' },
    { label: 'CORE', href: '/edir/edir_core' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            Questions
            <span class="hero-title-gradient">Sample Questions & Practice Resources</span>
          </h1>
          <p class="hero-description">
            Sample Multiple Response Questions (MRQ) to familiarise yourself with the EDiR MCQ question format and style.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">MRQ Practice Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
            <div class="stat-card"><p class="stat-card-text">Exam-Format Style</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Free Access</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">MRQ</div>
            <div class="stat-label">Practice Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Detailed</div>
            <div class="stat-label">Explanations</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Exam</div>
            <div class="stat-label">Format Style</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Free Access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- External Link -->
    <div class="container" style="text-align: center; margin-top: 2rem; margin-bottom: 1.5rem;">
      <a href="https://www.myebr.org/edir/all-about-the-examination" target="_blank" rel="noopener noreferrer" 
         style="display: inline-block; font-size: 1.3rem; font-weight: 700; padding: 1rem 2.5rem; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; border-radius: 12px; text-decoration: none; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
        📋 Official EDiR Exam Information &rarr;
      </a>
    </div>

    <!-- ==================== WRITTEN EXAM ==================== -->
    <section class="section section-edir-written" id="written-exam">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-edir-written">Written Exam</span>
          <h2 class="section-title text-center">Written Exam</h2>
          <p class="section-subtitle">Sample Multiple Response (MRQ) and Short Cases questions with detailed answers and explanations</p>
        </div>
        <MRQ
          sectionId="mrq-sample"
          title="Sample MRQ Question"
          subtitle="Live practice question in the Multiple Response format with answer and explanation"
        />

        <h3 class="section-title" style="margin-top: 2rem;">Sample Short Case Question</h3>

        <Shortcases questions={[
  {
    number: 1.1,
    stem: 'Concerning/In [Insert Topic or Core Statement Here]: / may include .jpg or .png images',
    statements: [
      { label: 'a', text: '[Statement 1]' },
      { label: 'b', text: '[Statement 2]' },
      { label: 'c', text: '[Statement 3]' },
      { label: 'd', text: '[Statement 4]' },
      { label: 'e', text: '[Statement 5]' },
    ],
    answers: [
      { label: 'a', text: 'Incorrect', correct: false },
      { label: 'b', text: 'Incorrect', correct: false },
      { label: 'c', text: 'Correct Best Answer', correct: true },
      { label: 'd', text: 'Incorrect', correct: false },
      { label: 'e', text: 'Incorrect', correct: false },
    ],
    explanation: '[Insert the detailed physics principle here. Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
    freeText: false,
  },
  {
    number: 1.2,
    stem: 'Concerning/In [Insert Another Topic or Core Statement Here]: / may include .jpg or .png images',
    statements: [
      { label: 'a', text: '[Statement A]' },
      { label: 'b', text: '[Statement B]' },
      { label: 'c', text: '[Statement C]' },
      { label: 'd', text: '[Statement D]' },
    ],
    answers: [
      { label: 'a', text: 'Incorrect', correct: false },
      { label: 'b', text: 'Correct Best Answer', correct: true },
      { label: 'c', text: 'Incorrect', correct: false },
      { label: 'd', text: 'Incorrect', correct: false },
    ],
    explanation: '[Insert the detailed physics principle here. Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
    freeText: false,
  },
  {
    number: 1.3,
    stem: 'Describe in your own words the key principles underlying [Insert Topic Here]:',
    statements: [],
    answers: [],
    explanation: '[Insert a model answer or key points that should be covered in the free-text response.]',
    freeText: true,
  },
]} />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== CORE EXAM ==================== -->
    <section class="section section-edir-core" id="core-exam">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-edir-core">Core Exam</span>
          <h2 class="section-title text-center">Core Exam</h2>
          <p class="section-subtitle">Sample Core Cases questions with detailed clinical reasoning and explanations</p>
        </div>
        <Corecases questions={[
  {
    number: 1.1,
    stem: 'Concerning/In [Insert Core Case Topic or Core Statement Here]: may have DICOM or .jpg/.png image references',
    statements: [
      { label: 'a', text: '[Statement 1]' },
      { label: 'b', text: '[Statement 2]' },
      { label: 'c', text: '[Statement 3]' },
      { label: 'd', text: '[Statement 4]' },
      { label: 'e', text: '[Statement 5]' },
    ],
    answers: [
      { label: 'a', text: 'Incorrect', correct: false },
      { label: 'b', text: 'Incorrect', correct: false },
      { label: 'c', text: 'Correct Best Answer', correct: true },
      { label: 'd', text: 'Incorrect', correct: false },
      { label: 'e', text: 'Incorrect', correct: false },
    ],
    explanation: '[Insert the detailed physics principle here. Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
    freeText: false,
  },
  {
    number: 1.2,
    stem: 'Concerning/In [Insert Another Core Case Topic or Core Statement Here]: / may include .jpg or .png images',
    statements: [
      { label: 'a', text: '[Statement A]' },
      { label: 'b', text: '[Statement B]' },
      { label: 'c', text: '[Statement C]' },
      { label: 'd', text: '[Statement D]' },
    ],
    answers: [
      { label: 'a', text: 'Incorrect', correct: false },
      { label: 'b', text: 'Correct Best Answer', correct: true },
      { label: 'c', text: 'Incorrect', correct: false },
      { label: 'd', text: 'Incorrect', correct: false },
    ],
    explanation: '[Insert the detailed physics principle here. Explain why the correct option is the best choice and why the other options are incorrect or less accurate.]',
    freeText: false,
  },
  {
    number: 1.3,
    stem: 'Describe in your own words the key principles underlying [Insert Topic Here]:',
    statements: [],
    answers: [],
    explanation: '[Insert a model answer or key points that should be covered in the free-text response.]',
    freeText: true,
  },
]} />
      </div>
    </section>
  </main>

  <Footer />
</Layout>