---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="MCQ – myEDiR - EDiR Exam - MyFRCR.com" theme="edir">
  <Navbar />
  <Subnav links={[
    { label: 'MCQ', href: '/edir/edir_mcq' },
    { label: 'Short Cases', href: '/edir/edir_shortcases' },
    { label: 'CORE', href: '/edir/edir_core' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            EDiR MCQ
            <span class="hero-title-gradient">Multiple Response Questions & Single Best Answer</span>
          </h1>
          <p class="hero-description">
            Master the MCQ component of your EDiR examination with Europe's most extensive question bank. Access 10,000+ single best answer and multiple response questions covering the entire European Training Curriculum, crafted by experienced consultant radiologists to mirror the official EDiR exam format.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">10,000+ SBA Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">Full Curriculum Coverage</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Radiologist-Created</p></div>
          </div>
          <div class="hero-actions">
            <a href="/edir/edir_pricing" class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">10,000+</div>
            <div class="stat-label">SBA Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">600+</div>
            <div class="stat-label">CORE Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">14</div>
            <div class="stat-label">Subspecialties</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About MCQ Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>About the EDiR MCQ Component</h2>
            <p>
              The EDiR MCQ component is designed to test your theoretical knowledge and clinical judgment across the entire European Training Curriculum. Unlike standard multiple-choice questions, these often require you to identify one or more correct answers (Multiple Response Questions), reflecting the complexity of real-world radiological decision-making.
            </p>
            <ul class="content-list">
              <li><strong>Comprehensive Coverage</strong> &mdash; Complete coverage of core topics across all subspecialties including physics, radiation safety, and pharmacology.</li>
              <li><strong>Exam-Format Simulation</strong> &mdash; The platform uses the same proportional scoring and question types found in the official EDiR exam.</li>
              <li><strong>Identify Knowledge Gaps</strong> &mdash; Instant scoring with detailed explanations helps pinpoint specific areas needing further refinement.</li>
              <li><strong>Performance Analytics</strong> &mdash; Track your progress across all subspecialties with detailed performance metrics.</li>
            </ul>
          </div>
          <div>
            <div class="content-images grid-2x2">
              <img src="/assets/myEDiRlogo lowercase.png" alt="EDiR" />
              <img src="/assets/myfrcrlogo.png" alt="MyFRCR" />
              <img src="/assets/myABRcorelogo.png" alt="ABR Core" />
              <img src="/assets/myRCPSClogo.png" alt="RCPSC" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Why Prepare with myEDiR.net?</h2>
        <p class="section-subtitle">Comprehensive MCQ preparation resources designed for EDiR exam success.</p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Extensive Question Bank</h3>
            <p class="feature-desc">10,000+ SBA and MRQ questions covering the entire EDiR training curriculum with detailed explanations.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Curriculum-Aligned</h3>
            <p class="feature-desc">Every question is mapped to the ESR curriculum, covering all major subspecialties and domains.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Detailed Explanations</h3>
            <p class="feature-desc">Examiner-style marking with comprehensive explanations for every question to deepen your understanding.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Performance Tracking</h3>
            <p class="feature-desc">Monitor your progress with detailed analytics and identify areas for improvement across all subspecialties.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Subspecialties Section -->
    <section class="offer-section">
      <div class="container">
        <div class="text-center">
          <div class="offer-header" style="justify-content: center;">
            <span>Subspecialties Covered</span>
          </div>
          <h2 class="offer-title">Complete EDiR MCQ Curriculum Coverage</h2>
          <p class="section-subtitle">Comprehensive MCQ coverage across all EDiR subspecialties as defined by the European Training Curriculum.</p>
        </div>
        <div class="subspecialty-grid" style="max-width: 48rem; margin: 0 auto;">
          <div class="subspecialty-item">Cardiothoracic Radiology</div>
          <div class="subspecialty-item">Emergency Radiology</div>
          <div class="subspecialty-item">Gastrointestinal Radiology</div>
          <div class="subspecialty-item">HPB Radiology</div>
          <div class="subspecialty-item">Head and Neck Radiology</div>
          <div class="subspecialty-item">Neuroradiology</div>
          <div class="subspecialty-item">Paediatric Neuroradiology</div>
          <div class="subspecialty-item">Spinal Radiology</div>
          <div class="subspecialty-item">Interventional Radiology</div>
          <div class="subspecialty-item">Paediatric Radiology</div>
          <div class="subspecialty-item">Chest Radiology</div>
          <div class="subspecialty-item">Uro-radiology</div>
          <div class="subspecialty-item">Breast Radiology</div>
          <div class="subspecialty-item">MSK Radiology</div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About myEDiR.net MCQ</h6>
            <h2 class="about-title">Why myEDiR.net Leads EDiR MCQ Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              MyEDiR.net provides the most comprehensive MCQ preparation for the European Diploma in Radiology, with an extensive question bank authored by experienced radiologists. Our platform delivers authentic exam practice with detailed explanations, helping you identify knowledge gaps and build confidence across the entire curriculum.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">10,000+ Questions</h4>
                <p class="about-stat-desc">Extensive SBA and MRQ bank covering all EDiR exam components.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by experienced consultant radiologists.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Detailed Explanations</h4>
                <p class="about-stat-desc">Comprehensive examiner-style marking and explanations for every question.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Curriculum Coverage</h4>
                <p class="about-stat-desc">Complete coverage mapped to the European Training Curriculum.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myEDiRlogo lowercase.png" alt="myEDiR Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>