---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRANZCR Phase 2 MCQ - MyFRCR.com" theme="franzcr">
  <Navbar />

  <main>
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            FRANZCR
            <span class="hero-title-gradient">Phase 2 MCQ</span>
          </h1>
          <p class="hero-description">
            Extensive multiple choice question bank covering all seven RANZCR clinical stations. 
            With over 10,000 MCQs on clinical radiology topics, you'll have comprehensive coverage 
            for the Phase 2 FRANZCR examination.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">10,000+ MCQs</p></div>
            <div class="stat-card"><p class="stat-card-text">7 RANZCR Stations</p></div>
            <div class="stat-card"><p class="stat-card-text">Radiologist-Created</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">10,000+</div>
            <div class="stat-label">MCQs</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">7</div>
            <div class="stat-label">Exam Stations</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Real-Time</div>
            <div class="stat-label">Performance Analytics</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>Phase 2 MCQ Overview</h2>
            <p>
              The Phase 2 MCQ bank provides comprehensive coverage of clinical radiology topics 
              aligned with the RANZCR curriculum. Each question is crafted by experienced consultant 
              radiologists to test your clinical knowledge, image interpretation skills, and 
              understanding of disease processes.
            </p>
            <ul class="content-list">
              <li><strong>Comprehensive Coverage</strong> &mdash; All seven RANZCR clinical stations covered in depth</li>
              <li><strong>Detailed Explanations</strong> &mdash; Learning-oriented feedback for each question with references</li>
              <li><strong>Exam-Style Format</strong> &mdash; Mirrors the actual FRANZCR Phase 2 MCQ examination</li>
              <li><strong>Performance Tracking</strong> &mdash; Monitor your progress across stations and subspecialties</li>
            </ul>
          </div>
          <div>
            <div class="feature-card" style="height: 100%;">
              <div class="feature-icon">
                <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
              </div>
              <h3 class="feature-title">Phase 2 MCQ Bank</h3>
              <p class="feature-desc">10,000+ MCQs covering all clinical radiology subspecialties, with detailed explanations and exam-style delivery.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stations Section -->
    <section class="section section-gray">
      <div class="container">
        <div class="text-center">
          <div class="offer-header" style="justify-content: center;">
            <span>Exam Stations</span>
          </div>
          <h2 class="offer-title">RANZCR Clinical Stations</h2>
          <p class="section-subtitle">Comprehensive MCQ coverage across all seven mandatory stations.</p>
        </div>
        <div class="subspecialty-grid" style="max-width: 36rem; margin: 2rem auto 0;">
          <div class="subspecialty-item">Abdominal (20%)</div>
          <div class="subspecialty-item">Neuroradiology / Head & Neck (15%)</div>
          <div class="subspecialty-item">Thoracic & Cardiovascular (15%)</div>
          <div class="subspecialty-item">Breast (5%)</div>
          <div class="subspecialty-item">Obstetrics & Gynaecology (5%)</div>
          <div class="subspecialty-item">Musculoskeletal (20%)</div>
          <div class="subspecialty-item">Paediatrics (20%)</div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section section-white">
      <div class="container">
        <div class="text-center">
          <h2 class="section-title">Key Features</h2>
          <p class="section-subtitle">Everything you need for comprehensive Phase 2 MCQ preparation</p>
        </div>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Curriculum-Aligned</h3>
            <p class="feature-desc">Every MCQ aligned with the RANZCR Clinical Radiology Training Program across all seven mandatory stations.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Detailed Explanations</h3>
            <p class="feature-desc">Comprehensive answer explanations with key learning points and references to help reinforce understanding.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Exam Simulation</h3>
            <p class="feature-desc">Practice with timed mock exams that replicate the actual Phase 2 MCQ examination experience.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Performance Analytics</h3>
            <p class="feature-desc">Track your performance across stations with detailed analytics to identify strengths and areas for improvement.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your FRANZCR Phase 2 MCQ</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">A$100</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">31 days of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">10,000+ MCQs</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">7 Exam Stations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Detailed Explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Performance Analytics</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
</write_to_file>