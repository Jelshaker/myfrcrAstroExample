---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="FRANZCR Pathology - MyFRCR.com" theme="franzcr">
  <Navbar />
  <Subnav links={[
    { label: 'Pathology MCQ & SAQ', href: '/franzcr/pathology' },
    { label: 'Phase 2 MCQ', href: '/franzcr/phase2-mcq' },
    { label: 'Case Reporting', href: '/franzcr/case-reporting' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            FRANZCR
            <span class="hero-title-gradient">Pathology MCQ & SAQ</span>
          </h1>
          <p class="hero-description">
            Comprehensive pathology question bank for the FRANZCR Phase 2 examination. 
            Featuring both multiple choice and short answer questions covering the full 
            RANZCR pathology curriculum.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">3,500+ Path Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">2,500+ Path MCQ</p></div>
            <div class="stat-card"><p class="stat-card-text">1,000+ Path SAQ</p></div>
            <div class="stat-card"><p class="stat-card-text">RANZCR Aligned</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">3,500+</div>
            <div class="stat-label">Path Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">2,500+</div>
            <div class="stat-label">Path MCQ</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">1,000+</div>
            <div class="stat-label">Path SAQ</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pathology MCQ Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <div class="offer-header">
              <span>Question Type</span>
            </div>
            <h2 class="offer-title">Pathology and Radiology MCQ</h2>
            <p>
              Extensive multiple choice question bank covering both pathology and radiology topics, 
              aligned with the RANZCR curriculum for comprehensive knowledge assessment. Each MCQ 
              is designed to test your understanding of disease processes, imaging findings, and 
              their clinical significance.
            </p>
            <ul class="content-list">
              <li><strong>Comprehensive Coverage</strong> &mdash; All subspecialties and pathology domains</li>
              <li><strong>Detailed Explanations</strong> &mdash; Learning-oriented feedback for each question</li>
              <li><strong>Exam-Style Format</strong> &mdash; Mirrors the actual FRANZCR MCQ examination</li>
              <li><strong>Performance Tracking</strong> &mdash; Monitor your progress across topics</li>
            </ul>
          </div>
          <div>
            <div class="feature-card" style="height: 100%;">
              <div class="feature-icon">
                <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
              </div>
              <h3 class="feature-title">Pathology MCQ</h3>
              <p class="feature-desc">2,500+ multiple choice questions covering pathology foundations, disease mechanisms, and radiology-pathology correlation essential for the FRANZCR exam.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pathology SAQ Section -->
    <section class="section section-gray">
      <div class="container">
        <div class="content-grid">
          <div>
            <div class="feature-card" style="height: 100%;">
              <div class="feature-icon">
                <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
              </div>
              <h3 class="feature-title">Pathology SAQ</h3>
              <p class="feature-desc">1,000+ short answer questions focused on pathology, designed to test detailed knowledge and understanding of disease processes relevant to radiology practice.</p>
            </div>
          </div>
          <div class="content-text">
            <div class="offer-header">
              <span>Question Type</span>
            </div>
            <h2 class="offer-title">Pathology SAQ</h2>
            <p>
              Short answer questions focused on pathology, designed to test detailed knowledge and 
              understanding of disease processes relevant to radiology practice. These questions 
              require concise, structured responses that demonstrate depth of understanding.
            </p>
            <ul class="content-list">
              <li><strong>Structured Answers</strong> &mdash; Practice writing concise, examiner-focused responses</li>
              <li><strong>Key Pathology Topics</strong> &mdash; Inflammation, neoplasia, vascular pathology, and more</li>
              <li><strong>Radiology-Pathology Correlation</strong> &mdash; Bridge the gap between imaging and pathology</li>
              <li><strong>Marking Schemes</strong> &mdash; Understand how examiners allocate marks</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Exam Structure Section -->
    <section class="offer-section">
      <div class="container">
        <div class="content-grid">
          <div>
            <div class="offer-header">
              <span>Exam Structure</span>
            </div>
            <h2 class="offer-title">Pathology Topics Covered</h2>
            <ul class="content-list">
              <li><strong>General Pathology</strong> &mdash; Cell injury, inflammation, repair, neoplasia</li>
              <li><strong>Systemic Pathology</strong> &mdash; Cardiovascular, respiratory, gastrointestinal, etc.</li>
              <li><strong>Paediatric Pathology</strong> &mdash; Developmental and congenital disorders</li>
              <li><strong>Radiation Pathology</strong> &mdash; Effects of radiation on tissues</li>
            </ul>
          </div>
          <div>
            <div class="offer-header">
              <span>Resources</span>
            </div>
            <h2 class="offer-title">Study Resources</h2>
            <div class="subspecialty-grid">
              <div class="subspecialty-item">Pathology MCQs</div>
              <div class="subspecialty-item">Pathology SAQs</div>
              <div class="subspecialty-item">Radiology-Pathology Cases</div>
              <div class="subspecialty-item">Examiner Tips</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your FRANZCR pathology exams</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">A$100</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">31 days of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">2,500+ Path MCQ</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">1,000+ Path SAQ</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Detailed Explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Performance Tracking</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About FRANZCR Pathology</h6>
            <h2 class="about-title">Comprehensive Pathology Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our FRANZCR pathology resource is designed to provide thorough coverage of the RANZCR 
              pathology curriculum. With thousands of carefully crafted MCQ and SAQ questions, you 
              can build a deep understanding of pathology as it relates to radiology practice.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">3,500+ Questions</h4>
                <p class="about-stat-desc">Comprehensive pathology question bank covering all key topics.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by experienced consultant radiologists.</p>
              </div>
            </div>
            <a href={`${import.meta.env.BASE_URL}contact`} class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src={`${import.meta.env.BASE_URL}assets/myFRANZCRlogo.png`} alt="FRANZCR Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>