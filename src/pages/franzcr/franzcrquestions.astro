---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
import MRQ from '../../components/questions/MRQ.astro';
import PathologySAQTemplate from '../../components/questions/pathologysaq.astro';
import FranzcrShortCase from '../../components/questions/franzcrshortcase.astro';
import FranzcrMediumCase from '../../components/questions/franzcrmediumcase.astro';
import FranzcrLongCase from '../../components/questions/franzcrlongcase.astro';
---

<Layout title="FranzCR Questions – FranzCR Exam - MyFRCR.com" theme="franzcr">
  <Navbar />
  <Subnav links={[
    { label: 'MCQ', href: '/franzcr/franzcr_mcq' },
    { label: 'Pathology', href: '/franzcr/franzcr_pathology' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            Questions
            <span class="hero-title-gradient">Pathology Section with MRQ & SAQ</span>
          </h1>
          <p class="hero-description">
            Sample Multiple Response Questions (MRQ) and Structured Written Answers (SAQ) for Pathology to familiarise yourself with the FranzCR question format and style.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">MRQ Practice Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">SAQ Clinical Cases</p></div>
            <div class="stat-card"><p class="stat-card-text">Detailed Explanations</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Free Access</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">MRQ</div>
            <div class="stat-label">Practice Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">SAQ</div>
            <div class="stat-label">Clinical Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Pathology</div>
            <div class="stat-label">Focused Section</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Free Access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== OFFICIAL RANZCR SAMPLE QUESTIONS PDF ==================== -->
    <div class="container" style="margin-top: 2rem; margin-bottom: 1rem;">
      <a
        href="https://www.ranzcr.com/wp-content/uploads/2023/05/Phase-2-Examination-Written-Sample-Questions-v-1.4.0.pdf"
        target="_blank"
        rel="noopener noreferrer"
        style="
          display: block;
          padding: 1.75rem 2rem;
          background: linear-gradient(135deg, #1a237e 0%, #283593 50%, #3949ab 100%);
          border-radius: 16px;
          text-align: center;
          color: #ffffff;
          text-decoration: none;
          font-size: 1.4rem;
          font-weight: 700;
          letter-spacing: 0.5px;
          box-shadow: 0 8px 32px rgba(26,35,126,0.3);
          transition: transform 0.2s, box-shadow 0.2s;
          border: 2px solid rgba(255,255,255,0.15);
        "
        onmouseover="this.style.transform='translateY(-3px)';this.style.boxShadow='0 12px 40px rgba(26,35,126,0.5)';"
        onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 32px rgba(26,35,126,0.3)';"
      >
        <div style="font-size: 1.0rem; margin-bottom: 0.25rem; opacity: 0.8; font-weight: 500;">Official RANZCR Resource</div>
        <div style="font-size: 1.6rem; line-height: 1.4;">📄 Phase 2 Examination Written Sample Questions</div>
        <div style="font-size: 1.0rem; margin-top: 0.35rem; opacity: 0.85;">Click to open the official PDF from RANZCR.com &nbsp;↗</div>
      </a>
    </div>

    <!-- ==================== PHASE 2 RADIOLOGY MCQ ==================== -->
    <section class="section section-franzcr-mcq" id="radiology-mcq">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-franzcr-mcq">Phase 2</span>
          <h2 class="section-title text-center">Phase 2 Radiology MCQ</h2>
          <p class="section-subtitle">Sample MRQ with detailed answers and explanations</p>
        </div>
        <MRQ
          sectionId="mrq-sample"
          title="Sample MRQ Question"
          subtitle="Live practice question in the Multiple Response format with answer and explanation"
        />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== PHASE 2 PATHOLOGY ==================== -->
    <section class="section section-franzcr-pathology" id="pathology-saq">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-franzcr-pathology">Phase 2</span>
          <h2 class="section-title text-center">Phase 2 Pathology - Pathology MCQ and Pathology SAQ</h2>
          <p class="section-subtitle">Clinical cases with structured marking criteria for pathology topics</p>
        </div>
        <PathologySAQTemplate
          title="Pathology SAQ Template"
          timeTarget="24 Marks (6 Marks Per Question)"
        />
      </div>
    </section>

    <!-- Exam Divider -->
    <div class="exam-divider">
      <div class="exam-divider-line"></div>
      <span class="exam-divider-label">Next Paper</span>
      <div class="exam-divider-line"></div>
    </div>

    <!-- ==================== CASE REPORTING ==================== -->
    <section class="section section-franzcr-casereporting" id="case-reporting">
      <div class="container">
        <div class="exam-header">
          <span class="exam-badge exam-badge-franzcr-cr">Case Reporting</span>
          <h2 class="section-title text-center">Case Reporting</h2>
          <p class="section-subtitle">Short, medium, and long case practice for the FranzCR Case Reporting exam component</p>
        </div>
        <FranzcrShortCase
          title="Case Reporting Short Case"
        />

        <FranzcrMediumCase
          title="Case Reporting Medium Case"
        />

        <FranzcrLongCase
          title="Case Reporting Long Case"
        />
      </div>
    </section>
  </main>

  <Footer />
</Layout>