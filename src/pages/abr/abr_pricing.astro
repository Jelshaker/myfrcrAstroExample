---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Card from '../../components/card.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="Pricing – ABR Core Exam - MyFRCR.com" theme="abr">
  <Navbar />
  <Subnav links={[
    { label: 'Qualifying (Core) Exam', href: '/abr/abr_core' },
    { label: 'Certifying Exam', href: '/abr/abr_certifying' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            ABR Pricing
            <span class="hero-title-gradient">Premium Access, Unbeatable Value</span>
          </h1>
          <p class="hero-description">
            Everything you need to pass your ABR Core and Certifying examinations. Access 10,000+ SBA questions, 600+ Core Cases, and full diagnostic workstation quality DICOM viewer — all at an affordable price.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">10,000+ SBA Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">600+ Core Cases</p></div>
            <div class="stat-card"><p class="stat-card-text">Full DICOM Viewer</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Radiologist-Created</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">10,000+</div>
            <div class="stat-label">SBA Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">600+</div>
            <div class="stat-label">CORE Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>1M</div>
            <div class="stat-label">DICOM Images</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">31 Days</div>
            <div class="stat-label">Full Access</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your ABR examinations</p>

        <div class="pricing-grid">
          <Card
            plan={{
              title: 'ABR Core (Qualifying) Exam',
              subtitle: '2 months of full access',
              price: '100',
              currency: '$',
              period: 'total',
              features: [
                { title: '10,000+ SBA Questions' },
                { title: '600+ Full Core Questions' },
                { title: 'Unlimited Practice' },
                { title: 'Examiner-style marking and explanations' },
                { title: 'Full diagnostic workstation quality DICOM Viewer' },
              ],
              ctaText: 'Get Core Access',
              ctaHref: '#',
              footerText: 'Cancel anytime \u2022 No automatic renewal',
              disclaimer: 'No automatic renewal. This is a one-time payment \u2014 you will not be charged again unless you choose to resubscribe.',
            }}
          />

          <Card
            plan={{
              title: 'ABR Certifying Exam',
              subtitle: '2 months of full access',
              price: '100',
              currency: '$',
              period: 'total',
              features: [
                { title: '5,000+ Advanced SBA Questions' },
                { title: '400+ Certifying Cases' },
                { title: 'Oral Board-Style Simulation' },
                { title: 'Examiner-style marking and explanations' },
                { title: 'Full diagnostic workstation quality DICOM Viewer' },
              ],
              ctaText: 'Get Certifying Access',
              ctaHref: '#',
              footerText: 'Cancel anytime \u2022 No automatic renewal',
              disclaimer: 'No automatic renewal. This is a one-time payment \u2014 you will not be charged again unless you choose to resubscribe.',
            }}
          />
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About ABR Pricing</h6>
            <h2 class="about-title">Invest in Your ABR Success</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our ABR exam preparation platform provides the most comprehensive revision resource available for the American Board of Radiology exams. With thousands of advanced-level questions, full lossless DICOM images, and expert-created content, you get exceptional value designed to help you succeed on your ABR Core and Certifying examinations.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">10,000+ Questions</h4>
                <p class="about-stat-desc">Comprehensive question bank covering the entire ABR curriculum.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by experienced consultant radiologists.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Full DICOM Quality</h4>
                <p class="about-stat-desc">Diagnostic workstation quality images following ACR guidelines.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">31-Day Access</h4>
                <p class="about-stat-desc">Full access to all content with no automatic renewal.</p>
              </div>
            </div>
            <a href={`${import.meta.env.BASE_URL}contact`} class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src={`${import.meta.env.BASE_URL}assets/myABRcorelogo.png`} alt="ABR Core Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .pricing-grid {
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
