---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
import FRCRLong from '../../components/questions/frcrlong.astro';
---

<Layout title="Certifying Exam – ABR Core Exam - MyFRCR.com" theme="abr">
  <Navbar />
  <Subnav links={[
    { label: 'Qualifying (Core) Exam', href: '/abr/abr_core' },
    { label: 'Certifying Exam', href: '/abr/abr_certifying' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            ABR Certifying Exam
            <span class="hero-title-gradient">American Board of Radiology Certification</span>
          </h1>
          <p class="hero-description">
            The final step to achieving American Board of Radiology Certification. Master the ABR Certifying Examination with authentic, expert-created content designed to mirror the actual exam format. Access advanced-level cases featuring full lossless DICOM images at diagnostic workstation quality.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">8,000+ Advanced Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">570+ Certifying Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">Subspecialty Coverage</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Radiologist-Created</p></div>
          </div>
          <div class="hero-actions">
            <a href={`${import.meta.env.BASE_URL}abr/abr_pricing`} class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">8,000+</div>
            <div class="stat-label">Advanced Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">570+</div>
            <div class="stat-label">Certifying Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">14</div>
            <div class="stat-label">Subspecialties Covered</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Certifying Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>About the ABR Certifying Exam</h2>
            <p>
              The ABR Certifying Examination evaluates your advanced knowledge and competency in diagnostic radiology subspecialties. This exam is designed for physicians who have successfully completed the Qualifying Examination. Our platform provides targeted resources to help you excel on this critical certifying step toward your fellowship certification.
            </p>
            <ul class="content-list">
              <li><strong>Format</strong> &mdash; Single Best Answer (SBA) questions</li>
              <li><strong>Duration</strong> &mdash; Approximately 4 hours</li>
              <li><strong>Number of Questions</strong> &mdash; ~570 certifying questions</li>
              <li><strong>Scheduling</strong> &mdash; Must be scheduled after passing the Core exam</li>
            </ul>
          </div>
          <div>
            <img src={`${import.meta.env.BASE_URL}assets/abr-certifying-banner.webp`} alt="ABR Certifying Exam Banner" class="rounded-lg shadow-md" />
          </div>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Why Prepare with MyFRCR?</h2>
        <p class="section-subtitle">Comprehensive preparation resources designed for ABR Certifying Exam success.</p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">Advanced Question Bank</h3>
            <p class="feature-desc">8,000+ SBA questions with advanced difficulty and subspecialty focus for certifying exam preparation.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">Subspecialty Coverage</h3>
            <p class="feature-desc">Comprehensive coverage of breast imaging, interventional radiology, nuclear medicine, and more subspecialties.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Advanced DICOM Viewer</h3>
            <p class="feature-desc">Full diagnostic workstation quality DICOM viewer for complex case-based question practice.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">Exam Simulation</h3>
            <p class="feature-desc">Practice within an interface that mirrors the official ABR platform with authentic marking schemes and timing.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Study Guide Section -->
    <section class="offer-section">
      <div class="container">
        <div class="content-grid">
          <div>
            <div class="offer-header">
              <span>Exam Structure</span>
            </div>
            <h2 class="offer-title">Exam Structure & Format</h2>
            <ul class="content-list">
              <li><strong>Format:</strong> Single Best Answer (SBA) questions</li>
              <li><strong>Duration:</strong> Approximately 4 hours</li>
              <li><strong>Number of Questions:</strong> ~570 certifying questions</li>
              <li><strong>Scheduling:</strong> Must be scheduled after passing the Core exam</li>
            </ul>
          </div>
          <div>
            <div class="offer-header">
              <span>Subspecialties</span>
            </div>
            <h2 class="offer-title">Subspecialty Areas</h2>
            <div class="subspecialty-grid">
              <div class="subspecialty-item">Breast Imaging</div>
              <div class="subspecialty-item">Vascular IR</div>
              <div class="subspecialty-item">Body Imaging</div>
              <div class="subspecialty-item">Nuclear Medicine</div>
              <div class="subspecialty-item">Interventional Neuroradiology</div>
              <div class="subspecialty-item">Pediatric Radiology</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sample Long Case Practice Section -->
    <section class="section section-gray" id="long-case-practice">
      <div class="container">
        <div class="exam-header">
          <h2 class="section-title text-center">Sample Long Case Practice</h2>
          <p class="section-subtitle">
            Practice with FRCR-style long case questions for advanced certifying exam preparation
          </p>
        </div>
        <FRCRLong
          title="FRCR Part 2B Long Case Practice"
        />
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your ABR Certifying Exam</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">$100</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">31 days of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">8,000+ Advanced Questions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">570+ Full Certifying Questions</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Examiner-style marking and explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Full diagnostic workstation quality DICOM Viewer</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About ABR Certifying</h6>
            <h2 class="about-title">Advanced Certifying Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our ABR Certifying exam preparation platform provides the most comprehensive revision resource available for the American Board of Radiology Certifying Exam. With thousands of advanced-level questions and full lossless DICOM images, you will be thoroughly prepared for this critical final step in your certification journey.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">8,000+ Questions</h4>
                <p class="about-stat-desc">Extensive question bank covering all certifying exam subspecialties.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by experienced consultant radiologists.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Full DICOM Quality</h4>
                <p class="about-stat-desc">Diagnostic workstation quality images following ACR guidelines.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Subspecialty Focus</h4>
                <p class="about-stat-desc">Advanced questions targeting certifying exam subspecialty areas.</p>
              </div>
            </div>
            <a href={`${import.meta.env.BASE_URL}contact`} class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src={`${import.meta.env.BASE_URL}assets/myABRcorelogo.png`} alt="ABR Certifying Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>