---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/navbar.astro';
import Subnav from '../../components/subnav.astro';
import Footer from '../../components/footer.astro';
---

<Layout title="Pricing – RCPSC Exam - MyFRCR.com" theme="rcpsc">
  <Navbar />
  <Subnav links={[
    { label: 'Paper 1: MCQ', href: '/rcpsc/rcpsc_mcq' },
    { label: 'Paper 2: SAQ', href: '/rcpsc/rcpsc_sba' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            RCPSC Pricing
            <span class="hero-title-gradient">Premium Access, Unbeatable Value</span>
          </h1>
          <p class="hero-description">
            Everything you need to pass your RCPSC examinations. Access comprehensive MCQ and SBA question banks, applied exam cases, and full diagnostic workstation quality DICOM viewer — all at an affordable price.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">Comprehensive MCQ Bank</p></div>
            <div class="stat-card"><p class="stat-card-text">Applied Exam Cases</p></div>
            <div class="stat-card"><p class="stat-card-text">Full DICOM Viewer</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Radiologist-Created</p></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">Comprehensive</div>
            <div class="stat-label">MCQ & SBA Bank</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Applied</div>
            <div class="stat-label">Exam Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">Full</div>
            <div class="stat-label">DICOM Quality</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">100%</div>
            <div class="stat-label">Radiologist-Created</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing-section" id="pricing">
      <div class="container">
        <h2 class="section-title text-center">Pricing</h2>
        <p class="section-subtitle">Everything you need to pass your RCPSC examination</p>
        <div class="pricing-card">
          <div class="pricing-header">
            <div class="pricing-subtitle">Premium Access</div>
            <div class="pricing-price">C$100</div>
            <p style="color: var(--color-gray-600); margin-top: 0.5rem;">31 days of full access</p>
          </div>
          <ul class="pricing-features">
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Comprehensive MCQ & SBA Bank</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Applied Exam Cases</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Unlimited Practice</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Examiner-style marking and explanations</span></div>
            </li>
            <li class="pricing-feature">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 512 512"><path d="M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z"/></svg>
              <div><span class="pricing-feature-title">Full diagnostic workstation quality DICOM Viewer</span></div>
            </li>
          </ul>
          <div class="pricing-separator"></div>
          <p style="text-align: center; font-weight: 600; color: var(--color-gray-700);">Secure Payment</p>
          <button class="pricing-cta">Get Started</button>
          <p class="pricing-footer-text">Cancel anytime &bull; No automatic renewal</p>
        </div>
        <p class="pricing-disclaimer">
          No automatic renewal. This is a one-time payment &mdash; you will not be charged again unless you choose to resubscribe.
        </p>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About RCPSC Pricing</h6>
            <h2 class="about-title">Invest in Your RCPSC Success</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              Our RCPSC exam preparation platform provides comprehensive revision resources for the Royal College of Physicians and Surgeons of Canada examinations. With extensive question banks, full lossless DICOM images, and expert-created content, you get exceptional value designed to help you succeed on your RCPSC exams.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Comprehensive Bank</h4>
                <p class="about-stat-desc">Extensive MCQ and SBA question bank for all RCPSC exam components.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Expert-Created</h4>
                <p class="about-stat-desc">Authored by experienced consultant radiologists.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Full DICOM Quality</h4>
                <p class="about-stat-desc">Diagnostic workstation quality images for authentic practice.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">31-Day Access</h4>
                <p class="about-stat-desc">Full access to all content with no automatic renewal.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myRCPSClogo.png" alt="RCPSC Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>