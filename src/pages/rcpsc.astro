---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/navbar.astro';
import Subnav from '../components/subnav.astro';
import Footer from '../components/footer.astro';
---

<Layout title="RCPSC - MyFRCR.com" theme="rcpsc">
  <Navbar />
  <Subnav links={[
    { label: 'Paper 1: MCQ', href: '/rcpsc/rcpsc_mcq' },
    { label: 'Paper 2: SAQ', href: '/rcpsc/rcpsc_sba' },
  ]} />

  <main class="has-subnav">
    <!-- Hero Section -->
    <section class="hero">
      <div class="hero-bg-pattern">
        <div class="hero-gradient-1"></div>
        <div class="hero-gradient-2"></div>
      </div>
      <div class="hero-content">
        <div class="hero-inner">
          <h1 class="hero-title">
            myRCPSC.com – Canada's Premier
            <span class="hero-title-gradient">RCPSC Exam Platform</span>
          </h1>
          <p class="hero-description">
            Master your Royal College of Physicians and Surgeons of Canada (RCPSC) examination with authentic, expert-created content. Access comprehensive revision resources featuring full lossless DICOM images at diagnostic workstation quality. Every question and answer is meticulously crafted by experienced radiologists.
          </p>
          <div class="hero-stats">
            <div class="stat-card"><p class="stat-card-text">Comprehensive MCQ Bank</p></div>
            <div class="stat-card"><p class="stat-card-text">SBA Questions</p></div>
            <div class="stat-card"><p class="stat-card-text">Applied Exam Prep</p></div>
            <div class="stat-card"><p class="stat-card-text">100% Human-Created</p></div>
          </div>
          <div class="hero-actions">
            <a href="/rcpsc/rcpsc_pricing" class="btn-hero">
              View Pricing
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
            <a href="#about" class="btn-hero-outline">
              Learn More
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24" height="32" width="32">
                <path fill="none" d="M0 0h24v24H0V0z"></path>
                <path d="M8.59 16.59 13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <div class="hero-scroll">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <div class="stat-number">10,000+</div>
            <div class="stat-label">Questions</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">600+</div>
            <div class="stat-label">CORE Cases</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>1M</div>
            <div class="stat-label">DICOM Images</div>
          </div>
          <div class="stat-item">
            <div class="stat-number">>500GB</div>
            <div class="stat-label">Medical Imaging</div>
          </div>
        </div>
      </div>
    </section>

    <!-- What is myRCPSC Section -->
    <section class="section section-white">
      <div class="container">
        <div class="content-grid">
          <div class="content-text">
            <h2>What is myRCPSC.com?</h2>
            <p>
              myRCPSC.com is the most comprehensive revision resource available for the Royal College of Physicians and Surgeons of Canada radiology examinations. Our database allows for complete coverage of the RCPSC curriculum across all subspecialties and exam components. Thousands of high-quality image studies are integrated into a vast array of clinically-oriented cases.
            </p>
            <ul class="content-list">
              <li><strong>Full Lossless DICOM Images</strong> &mdash; Diagnostic workstation quality following Canadian PACS guidelines</li>
              <li><strong>100% Radiologist-Created</strong> &mdash; Expert consultant radiologists &ndash; zero AI cases</li>
              <li><strong>Complete Coverage of the Curriculum</strong> &mdash; Every subspecialty across thousands of high-quality questions</li>
              <li><strong>Realistic Exam Simulation</strong> &mdash; Authentic conditions with examiner-style feedback</li>
            </ul>
          </div>
          <div>
            <div class="content-images grid-2x2">
              <img src="/assets/myRCPSClogo.png" alt="RCPSC" />
              <img src="/assets/myfrcrlogo.png" alt="MyFRCR" />
              <img src="/assets/myABRcorelogo.png" alt="ABR Core" />
              <img src="/assets/myFRANZCRlogo.png" alt="FRANZCR" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Exam Components Section -->
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title text-center">Exam Components</h2>
        <p class="section-subtitle">Comprehensive preparation across all RCPSC exam components.</p>
        <div class="features-grid" style="margin-top: 2rem;">
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M18.435,3.06H5.565a2.5,2.5,0,0,0-2.5,2.5v8.88a2.507,2.507,0,0,0,2.5,2.5h2.91l-.37,3H7a.5.5,0,0,0,0,1h10.01a.5.5,0,0,0,0-1H15.9l-.37-3h2.91a2.507,2.507,0,0,0,2.5-2.5V5.56A2.5,2.5,0,0,0,18.435,3.06Z"/></svg>
            </div>
            <h3 class="feature-title">MCQ Bank</h3>
            <p class="feature-desc">Comprehensive multiple choice questions covering the entire RCPSC curriculum.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="M5 8.999c0 1.902.765 3.627 2 4.89V21a.998.998 0 0 0 1.447.895L12 20.118l3.553 1.776a.992.992 0 0 0 .972-.043c.295-.183.475-.504.475-.851v-7.11a6.976 6.976 0 0 0 2-4.891C19 5.14 15.86 2 12 2S5 5.14 5 8.999z"/></svg>
            </div>
            <h3 class="feature-title">SBA Questions</h3>
            <p class="feature-desc">Single best answer questions designed to test clinical reasoning and judgment.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 32 32"><path d="M16 27.534c-5.323 0-9.641-1.44-9.641-3.214 0-0.97 0-2.031 0-3.214 0-0.279 0.14-0.545 0.341-0.803 1.075 1.384 4.813 2.41 9.301 2.41s8.226-1.026 9.301-2.41c0.201 0.259 0.34 0.524 0.34 0.803 0 0.931 0 1.918 0 3.214 0 1.773-4.318 3.214-9.641 3.214z"/></svg>
            </div>
            <h3 class="feature-title">Applied Examination</h3>
            <p class="feature-desc">Practice with cases that mirror the applied exam format with structured assessment.</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">
              <svg stroke="currentColor" fill="currentColor" viewBox="0 0 24 24"><path d="m10 10.414 4 4 5.707-5.707L22 11V5h-6l2.293 2.293L14 11.586l-4-4-7.707 7.707 1.414 1.414z"/></svg>
            </div>
            <h3 class="feature-title">DICOM Viewer</h3>
            <p class="feature-desc">Full diagnostic workstation quality DICOM viewer for authentic exam practice.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section class="about-section" id="about">
      <div class="container">
        <div class="about-grid">
          <div>
            <h6 class="about-label">About myRCPSC.com</h6>
            <h2 class="about-title">Why myRCPSC Leads RCPSC Preparation</h2>
            <p class="about-desc" style="margin-top: 1rem;">
              myRCPSC.com is the premier platform for the Royal College of Physicians and Surgeons of Canada radiology examinations, offering an extensive database of authentic cases, MCQs, and SBA questions. Our commitment to expert-created content with full lossless DICOM quality ensures candidates receive genuine exam preparation that aligns with Canadian standards.
            </p>
            <div class="about-stats-grid" style="margin-top: 1.5rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">Thousands of DICOM Studies</h4>
                <p class="about-stat-desc">A vast library of radiographs, CT, and MRI studies delivered in full lossless DICOM format.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">Enterprise Infrastructure</h4>
                <p class="about-stat-desc">Custom DICOM viewer powered by enterprise cloud infrastructure.</p>
              </div>
            </div>
            <div class="about-stats-grid" style="margin-top: 1rem;">
              <div class="about-stat-card">
                <h4 class="about-stat-number">RCPSC Guidelines Compliant</h4>
                <p class="about-stat-desc">Following international PACS display guidelines for diagnostic workstations.</p>
              </div>
              <div class="about-stat-card">
                <h4 class="about-stat-number">100% Human-Made</h4>
                <p class="about-stat-desc">All clinical cases authored by expert human consultant radiologists.</p>
              </div>
            </div>
            <a href="/contact" class="read-more-link" style="margin-top: 1.5rem;">
              <span>Contact Us</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                <path d="M6.75265 4.49658L11.2528 8.99677L6.75 13.4996" stroke="#4F46E5" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </a>
          </div>
          <div style="display: flex; justify-content: center; align-items: center;">
            <div style="width: 100%; max-width: 564px; background: var(--color-gray-100); border-radius: var(--radius-2xl); border: 1px solid var(--color-gray-200); padding: 1.25rem;">
              <img src="/assets/myRCPSClogo.png" alt="RCPSC Platform" style="width: 100%; height: auto; border-radius: var(--radius-2xl); object-fit: cover;" />
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>